<section class="min-h-screen px-6 py-10">
  <div class="max-w-2xl mx-auto">

    <div class="flex items-center gap-3 mb-8">
      <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-[#3F5F45] to-[#2F3E34] flex items-center justify-center shadow">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
      </div>
      <div>
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Documentos para aprovação</h1>
        <p class="text-sm text-slate-500 dark:text-white/50">Envie documentos para validação da sua ONG</p>
      </div>
    </div>

    <!-- Status de aprovação -->
    <div class="mb-6 p-4 rounded-xl border {{#if isAprovada}}bg-green-50 dark:bg-green-900/20 border-green-200 dark:border-green-500/30{{else if isRejeitada}}bg-red-50 dark:bg-red-900/20 border-red-200 dark:border-red-500/30{{else}}bg-[#EAF3EC] dark:bg-[#6B8F71]/20 border-[#DDEADB] dark:border-[#6B8F71]/30{{/if}}">
      <div class="flex items-center gap-3">
        {{#if isAprovada}}
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-green-600 dark:text-green-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        <div>
          <p class="text-sm font-semibold text-green-700 dark:text-green-400">ONG aprovada</p>
          <p class="text-xs text-green-600 dark:text-green-500">Sua organização foi validada e está ativa na plataforma.</p>
        </div>
        {{else if isRejeitada}}
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-red-600 dark:text-red-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        <div>
          <p class="text-sm font-semibold text-red-700 dark:text-red-400">Aprovação rejeitada</p>
          {{#if observacaoAdmin}}<p class="text-xs text-red-600 dark:text-red-500 mt-0.5">Motivo: {{observacaoAdmin}}</p>{{/if}}
          <p class="text-xs text-red-600 dark:text-red-500 mt-1">Envie os documentos corretos e aguarde nova análise.</p>
        </div>
        {{else}}
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[#3F5F45] dark:text-[#DDEADB] flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        <div>
          <p class="text-sm font-semibold text-[#3F5F45] dark:text-[#DDEADB]">Aprovação pendente</p>
          <p class="text-xs text-[#3F5F45] dark:text-[#DDEADB]">Envie seus documentos para colocar sua ONG em pendente de validação e aguardar a análise da equipe.</p>
        </div>
        {{/if}}
      </div>
    </div>

    {{#if success}}
    <div class="flex items-center gap-3 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-500/30 text-green-700 dark:text-green-400 p-4 rounded-xl mb-5 text-sm">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
      Documento enviado com sucesso!
    </div>
    {{/if}}

    <!-- Upload -->
    <div class="bg-white dark:bg-[#3F5F45]/20 border border-slate-200 dark:border-white/10 rounded-2xl p-6 shadow-sm mb-6">
      <h2 class="text-sm font-semibold text-slate-500 dark:text-white/50 uppercase tracking-wider mb-4">Enviar documento</h2>
      <p class="text-sm text-slate-500 dark:text-white/50 mb-4">
        Após o envio, a documentação permanece com status pendente de validação até a revisão administrativa.
      </p>
      <form method="POST" action="/ong/documentos" enctype="multipart/form-data" class="space-y-4">

        <div>
          <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">Tipo de documento</label>
          <select name="tipo"
            class="w-full rounded-xl p-3 border border-slate-200 dark:border-white/10 bg-white dark:bg-white/5 dark:[color-scheme:dark] text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-[#6B8F71]">
            <option value="estatuto">Estatuto social</option>
            <option value="cnpj">Comprovante de CNPJ</option>
            <option value="ata">Ata de eleição da diretoria</option>
            <option value="documento">Outro documento</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">Arquivo <span class="font-normal text-slate-400 dark:text-white/40">(PDF, JPG, PNG - máx. 5MB)</span></label>
          <input type="file" name="file" accept=".pdf,image/jpeg,image/png,image/webp" required
            class="w-full text-sm text-slate-600 dark:text-white/70 file:mr-3 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-[#3F5F45]/10 file:text-[#3F5F45] dark:file:text-white/80 dark:file:bg-white/10 file:font-medium hover:file:opacity-80 cursor-pointer" />
        </div>

        <button type="submit"
          class="w-full bg-gradient-to-r from-[#3F5F45] to-[#2F3E34] hover:opacity-90 text-white py-3 rounded-xl font-semibold transition shadow text-sm">
          Enviar documento
        </button>

      </form>
    </div>

    <!-- Documentos enviados -->
    {{#if documentos.length}}
    <div class="bg-white dark:bg-[#3F5F45]/20 border border-slate-200 dark:border-white/10 rounded-2xl p-6 shadow-sm">
      <h2 class="text-sm font-semibold text-slate-500 dark:text-white/50 uppercase tracking-wider mb-4">Documentos enviados</h2>
      <div class="space-y-3">
        {{#each documentos}}
        <div class="flex items-center gap-3 py-2 border-b border-slate-100 dark:border-white/5 last:border-0">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-400 dark:text-white/40 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-slate-800 dark:text-white truncate">{{nome_arquivo}}</p>
            <p class="text-xs text-slate-400 dark:text-white/40">{{tipo}} · {{criado_em}}</p>
          </div>
          <a href="{{arquivo_url}}" target="_blank" class="text-xs text-[#3F5F45] dark:text-[#6B8F71] font-medium hover:opacity-80">Ver</a>
        </div>
        {{/each}}
      </div>
    </div>
    {{/if}}

  </div>
</section>
