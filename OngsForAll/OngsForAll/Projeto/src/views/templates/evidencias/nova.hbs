<section class="min-h-screen px-6 py-10">
  <div class="max-w-xl mx-auto">

    <div class="flex items-center gap-3 mb-8">
      <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-[#6B8F71] to-[#2F3E34] flex items-center justify-center shadow">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
      <div>
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Adicionar evidência</h1>
        <p class="text-sm text-slate-500 dark:text-white/50">Comprovação do recebimento — interesse #{{interesseId}}</p>
      </div>
    </div>

    {{#if success}}
    <div class="flex items-center gap-3 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-500/30 text-green-700 dark:text-green-400 p-4 rounded-xl mb-6 text-sm">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
      Evidência enviada com sucesso!
    </div>
    {{/if}}

    <div class="bg-white dark:bg-[#102235] border border-slate-200 dark:border-white/10 rounded-2xl p-6 shadow-sm">

      <form method="POST" action="/ong/interesses/{{interesseId}}/evidencia" enctype="multipart/form-data" class="space-y-5">

        <div>
          <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-2">Imagem de comprovação</label>
          <div class="border-2 border-dashed border-slate-200 dark:border-white/20 rounded-xl p-8 text-center cursor-pointer hover:border-[#6B8F71] dark:hover:border-[#6B8F71] transition" id="drop-zone">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 mx-auto mb-3 text-slate-300 dark:text-white/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <p class="text-sm text-slate-500 dark:text-white/50 mb-1">Clique para selecionar ou arraste a imagem aqui</p>
            <p class="text-xs text-slate-400 dark:text-white/30">JPG, PNG ou WebP — máximo 3MB</p>
            <input type="file" name="file" accept="image/jpeg,image/png,image/webp" required
              class="hidden" id="file-input" />
          </div>
          <div id="preview-container" class="hidden mt-3">
            <img id="preview-img" src="" alt="Pré-visualização" class="max-h-48 rounded-xl mx-auto border border-slate-200 dark:border-white/10" />
            <p id="preview-name" class="text-xs text-center text-slate-500 dark:text-white/50 mt-2"></p>
          </div>
        </div>

        <div>
          <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">Legenda <span class="font-normal text-slate-400 dark:text-white/40">(opcional)</span></label>
          <input type="text" name="legenda" maxlength="255"
            class="w-full rounded-xl p-3 border border-slate-200 dark:border-white/10 bg-white dark:bg-white/5 text-slate-900 dark:text-white placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-[#6B8F71]"
            placeholder="Descreva brevemente o que a imagem mostra" />
        </div>

        <div class="flex gap-3">
          <a href="/ong/interesses"
            class="flex-1 text-center py-3 rounded-xl border border-slate-200 dark:border-white/10 text-sm font-medium text-slate-600 dark:text-white/70 hover:opacity-80 transition">
            Voltar
          </a>
          <button type="submit"
            class="flex-1 bg-gradient-to-r from-[#6B8F71] to-[#2F3E34] hover:opacity-90 text-white py-3 rounded-xl font-semibold transition shadow text-sm">
            Enviar evidência
          </button>
        </div>

      </form>
    </div>

  </div>
</section>

<script>
(function () {
  const zone = document.getElementById('drop-zone');
  const input = document.getElementById('file-input');
  const preview = document.getElementById('preview-container');
  const img = document.getElementById('preview-img');
  const name = document.getElementById('preview-name');

  zone.addEventListener('click', () => input.click());

  zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('border-[#6B8F71]'); });
  zone.addEventListener('dragleave', () => zone.classList.remove('border-[#6B8F71]'));
  zone.addEventListener('drop', e => {
    e.preventDefault();
    zone.classList.remove('border-[#6B8F71]');
    const file = e.dataTransfer.files[0];
    if (file) handleFile(file);
  });

  input.addEventListener('change', () => {
    if (input.files[0]) handleFile(input.files[0]);
  });

  function handleFile(file) {
    const dt = new DataTransfer();
    dt.items.add(file);
    input.files = dt.files;

    const reader = new FileReader();
    reader.onload = e => {
      img.src = e.target.result;
      name.textContent = file.name;
      preview.classList.remove('hidden');
    };
    reader.readAsDataURL(file);
  }
})();
</script>
