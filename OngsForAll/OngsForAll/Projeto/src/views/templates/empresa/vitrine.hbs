<div class="max-w-4xl mx-auto space-y-6">

  <div class="flex items-center justify-between flex-wrap gap-3">
    <div>
      <h2 class="text-2xl font-bold text-[#2D4BA6] dark:text-white">Minha vitrine</h2>
      <p class="text-sm text-slate-500 dark:text-white/60 mt-0.5">Gerencie seus itens publicados no marketplace</p>
    </div>
    {{#unless isBloqueada}}
    <a href="/empresa/vitrine/novo"
      class="px-5 py-2.5 rounded-2xl bg-gradient-to-r from-violet-500 to-purple-700 text-white text-sm font-bold shadow hover:opacity-90 transition">
      + Novo item
    </a>
    {{/unless}}
  </div>

  {{#if success}}
  <div class="flex items-center gap-3 px-4 py-3 rounded-xl bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-200 dark:border-emerald-800 text-emerald-700 dark:text-emerald-300 text-sm font-medium">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
    </svg>
    {{#if successComImagem}}Item com imagem enviado para moderação com sucesso!{{else}}Item enviado para moderação com sucesso!{{/if}}
  </div>
  {{/if}}

  {{#if successEditado}}
  <div class="flex items-center gap-3 px-4 py-3 rounded-xl bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 text-blue-700 dark:text-blue-300 text-sm font-medium">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
    </svg>
    Item atualizado com sucesso.
  </div>
  {{/if}}

  {{#if successDesativado}}
  <div class="flex items-center gap-3 px-4 py-3 rounded-xl bg-slate-50 dark:bg-white/5 border border-slate-200 dark:border-white/10 text-slate-700 dark:text-white/80 text-sm font-medium">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
    Item desativado e movido para rascunho.
  </div>
  {{/if}}

  {{#if successReenviado}}
  <div class="flex items-center gap-3 px-4 py-3 rounded-xl bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 text-amber-700 dark:text-amber-300 text-sm font-medium">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v6h6M20 20v-6h-6M5.636 18.364a9 9 0 1112.728 0" />
    </svg>
    Item reenviado para moderação.
  </div>
  {{/if}}

  {{#if erro}}
  <div class="flex items-center gap-3 px-4 py-3 rounded-xl bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-300 text-sm font-medium">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    {{erro}}
  </div>
  {{/if}}

  {{#if isBloqueada}}
  <div class="bg-white dark:bg-[#102235] border border-slate-200 dark:border-white/10 rounded-2xl p-10 shadow-sm text-center">
    <div class="w-16 h-16 rounded-2xl bg-slate-100 dark:bg-white/5 flex items-center justify-center mx-auto mb-4">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-slate-400 dark:text-white/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
      </svg>
    </div>
    <p class="text-slate-600 dark:text-white/70 font-semibold">Vitrine bloqueada</p>
    <p class="text-sm text-slate-400 dark:text-white/40 mt-2 max-w-sm mx-auto">
      Apoie pelo menos 3 necessidades de ONGs para desbloquear sua vitrine no marketplace social.
    </p>
    <a href="/empresa/necessidades"
      class="mt-5 inline-block px-5 py-2.5 rounded-2xl bg-gradient-to-r from-violet-500 to-purple-700 text-white text-sm font-bold shadow hover:opacity-90 transition">
      Apoiar necessidades
    </a>
  </div>

  {{else if itens.length}}
  <div class="space-y-3">
    {{#each itens}}
    <div class="flex items-center gap-4 bg-white dark:bg-[#102235] border border-slate-200 dark:border-white/10 rounded-2xl p-4 shadow-sm">
      {{#if imagem_url}}
      <img src="{{imagem_url}}" alt="Imagem do item {{titulo}}" class="w-14 h-14 rounded-xl object-cover shrink-0 border border-slate-200 dark:border-white/10" />
      {{else}}
      <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-violet-50 to-blue-50 dark:from-violet-900/20 dark:to-blue-900/20 border border-violet-100 dark:border-violet-500/20 flex items-center justify-center shrink-0 text-violet-300 dark:text-violet-200/50">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
      {{/if}}
      <div class="flex-1 min-w-0">
        <p class="font-semibold text-[#2D4BA6] dark:text-white text-sm truncate">{{titulo}}</p>
        <p class="text-xs text-slate-400 dark:text-white/40 mt-0.5">{{tipoLabel}} · {{criado_em}}</p>
        {{#if precoLabel}}
        <span class="inline-block mt-1 px-2 py-0.5 rounded-full text-[10px] font-semibold
          {{#if isGratuito}}bg-emerald-50 text-emerald-600 dark:bg-emerald-900/20 dark:text-emerald-400{{else}}{{#if isFixo}}bg-blue-50 text-blue-600 dark:bg-blue-900/20 dark:text-blue-400{{else}}bg-slate-100 text-slate-500 dark:bg-white/10 dark:text-white/50{{/if}}{{/if}}">
          {{precoLabel}}
        </span>
        {{/if}}
        {{#if observacao_admin}}
        <p class="text-xs text-red-500 mt-1">Obs. admin: {{observacao_admin}}</p>
        {{/if}}
      </div>
      <div class="shrink-0 flex items-center gap-2">
        <a href="/empresa/vitrine/{{id}}/editar"
          title="Editar item"
          class="flex items-center justify-center w-8 h-8 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-500 dark:text-white/50 hover:border-violet-400 hover:text-violet-600 dark:hover:text-violet-400 transition">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
          </svg>
        </a>

        {{#if canReenviar}}
        <form method="POST" action="/empresa/vitrine/{{id}}/reenviar">
          <button type="submit"
            class="px-2.5 py-1 rounded-lg text-[11px] font-semibold bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-300 hover:opacity-90 transition">
            Reenviar
          </button>
        </form>
        {{/if}}

        {{#if canDesativar}}
        <form method="POST" action="/empresa/vitrine/{{id}}/desativar">
          <button type="submit"
            class="px-2.5 py-1 rounded-lg text-[11px] font-semibold bg-slate-100 text-slate-700 dark:bg-white/10 dark:text-white/70 hover:opacity-90 transition">
            Desativar
          </button>
        </form>
        {{/if}}
      </div>
      <span class="shrink-0 px-2.5 py-1 rounded-full text-xs font-semibold
        {{#if isAprovado}}bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-300{{/if}}
        {{#if isPendente}}bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-300{{/if}}
        {{#if isRejeitado}}bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-300{{/if}}
        {{#if isRascunho}}bg-slate-100 text-slate-600 dark:bg-white/10 dark:text-white/60{{/if}}">
        {{statusLabel}}
      </span>
    </div>
    {{/each}}
  </div>

  {{else}}
  <div class="bg-white dark:bg-[#102235] border border-slate-200 dark:border-white/10 rounded-2xl p-10 shadow-sm text-center">
    <p class="text-slate-500 dark:text-white/50 font-medium">Nenhum item publicado ainda</p>
    <a href="/empresa/vitrine/novo"
      class="mt-4 inline-block px-5 py-2.5 rounded-2xl bg-gradient-to-r from-violet-500 to-purple-700 text-white text-sm font-bold shadow hover:opacity-90 transition">
      Publicar primeiro item
    </a>
  </div>
  {{/if}}

</div>
