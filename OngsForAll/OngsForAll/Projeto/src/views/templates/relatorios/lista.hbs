<section class="min-h-screen px-6 py-10">
  <div class="max-w-5xl mx-auto">

    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-8">
      <div class="flex items-center gap-3">
        <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-[#3F5F45] to-[#2F3E34] flex items-center justify-center shadow">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Relatórios de impacto</h1>
      </div>
      <a href="/ong/relatorios/novo"
        class="inline-flex items-center gap-2 bg-gradient-to-r from-[#3F5F45] to-[#2F3E34] text-white px-5 py-2.5 rounded-xl font-semibold text-sm shadow hover:opacity-90 transition">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
        Novo relatório
      </a>
    </div>

    {{#if success}}
    <div class="flex items-center gap-3 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-500/30 text-green-700 dark:text-green-400 p-4 rounded-xl mb-6 text-sm">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
      Relatório criado com sucesso!
    </div>
    {{/if}}

    {{#if relatorios.length}}
    <div class="space-y-4">
      {{#each relatorios}}
      <div class="bg-white dark:bg-[#3F5F45]/20 border border-slate-200 dark:border-white/10 rounded-2xl p-5 shadow-sm">
        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-3">
          <div class="flex-1">
            <div class="flex items-center gap-2 mb-2">
              {{#if isPublicado}}
              <span class="px-2.5 py-1 rounded-full bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 text-xs font-semibold">Publicado</span>
              {{else}}
              <span class="px-2.5 py-1 rounded-full bg-slate-100 dark:bg-white/10 text-slate-600 dark:text-white/60 text-xs font-semibold">Rascunho</span>
              {{/if}}
              {{#if titulo_necessidade}}
              <span class="px-2.5 py-1 rounded-full bg-[#EAF3EC] dark:bg-[#6B8F71]/20 text-[#3F5F45] dark:text-[#DDEADB] text-xs font-medium">{{titulo_necessidade}}</span>
              {{/if}}
            </div>
            <h2 class="text-base font-bold text-slate-900 dark:text-white mb-1">{{titulo}}</h2>
            <p class="text-sm text-slate-500 dark:text-white/50 line-clamp-2">{{descricao}}</p>
          </div>
          <div class="flex flex-col items-end gap-2 shrink-0">
            <span class="text-xs text-slate-400 dark:text-white/40">{{data_publicacao}}</span>
            {{#if pessoas_beneficiadas}}
            <span class="text-xs font-semibold text-slate-600 dark:text-white/60">{{pessoas_beneficiadas}} beneficiados</span>
            {{/if}}
            <a href="/relatorios/{{id}}"
              class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg border border-slate-200 dark:border-white/10 text-xs font-medium text-slate-600 dark:text-white/70 hover:opacity-80 transition">
              Ver relatório
            </a>
          </div>
        </div>
      </div>
      {{/each}}
    </div>
    {{else}}
    {{> emptyState message="Nenhum relatório criado ainda."}}
    {{/if}}

  </div>
</section>
