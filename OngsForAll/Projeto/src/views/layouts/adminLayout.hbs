<!DOCTYPE html>
<html lang="pt-br" class="h-full">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin — ONGs For All</title>
  <link rel="stylesheet" href="/public/dist/global.css">
</head>

<body class="min-h-screen bg-slate-100 dark:bg-[#0D1B2A] text-slate-900 dark:text-white transition-colors duration-300">

  <!-- Topbar -->
  <header class="sticky top-0 z-50 bg-white dark:bg-[#0D1B2A] border-b border-slate-200 dark:border-white/10 shadow-sm">
    <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between gap-6">

      <!-- Logo + título -->
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 rounded-xl bg-gradient-to-br from-[#2D4BA6] to-[#4886D9] flex items-center justify-center shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
        </div>
        <span class="font-bold text-sm text-[#2D4BA6] dark:text-white">ONGs For All</span>
        <span class="text-slate-300 dark:text-white/20 text-sm">·</span>
        <span class="text-xs font-semibold text-slate-500 dark:text-white/50 uppercase tracking-wider">Painel Admin</span>
      </div>

      <!-- Navegação -->
      <nav class="flex items-center gap-1">
        <a href="/admin/ongs"
          class="px-3 py-1.5 rounded-lg text-sm font-semibold transition
            {{#if adminPageOngs}}bg-[#2D4BA6]/10 text-[#2D4BA6] dark:bg-[#4886D9]/20 dark:text-[#4886D9]{{else}}text-slate-600 dark:text-white/60 hover:bg-slate-100 dark:hover:bg-white/5{{/if}}">
          ONGs
        </a>
        <a href="/admin/marketplace"
          class="px-3 py-1.5 rounded-lg text-sm font-semibold transition
            {{#if adminPageMarketplace}}bg-[#2D4BA6]/10 text-[#2D4BA6] dark:bg-[#4886D9]/20 dark:text-[#4886D9]{{else}}text-slate-600 dark:text-white/60 hover:bg-slate-100 dark:hover:bg-white/5{{/if}}">
          Marketplace
        </a>
      </nav>

    </div>
  </header>

  <!-- Conteúdo -->
  <main class="max-w-6xl mx-auto px-6 py-8">
    {{{body}}}
  </main>

</body>
</html>
