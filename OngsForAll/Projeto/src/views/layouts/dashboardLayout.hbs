<!DOCTYPE html>
<html lang="pt-br" class="bg-white text-gray-900 dark:bg-[#0D1B2A] dark:text-white">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{title}}{{#if stitle}} - {{stitle}}{{/if}}</title>

  <link rel="stylesheet" href="/public/dist/global.css" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    (function () {
      var theme = localStorage.getItem('theme');
      if (!theme) theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      if (theme === 'dark') document.documentElement.classList.add('dark');
      else document.documentElement.classList.remove('dark');
    })();
  </script>
</head>

<body class="min-h-screen bg-[#F8FAFC] text-[#2D4BA6] dark:bg-[#0D1B2A] dark:text-white transition-colors duration-300">
  <div class="min-h-screen flex">

    <!-- Sidebar usuário -->
    <aside
      class="hidden lg:flex w-72 flex-col bg-white border-r border-slate-200 dark:bg-[#102235] dark:border-white/10 shadow-sm">
      <div class="px-6 py-6 border-b border-slate-200 dark:border-white/10">
        <div class="flex items-center gap-3">
          <div
            class="w-12 h-12 rounded-2xl bg-gradient-to-br from-[#4886D9] to-[#2D4BA6] flex items-center justify-center text-white font-bold text-lg shadow-md">
            U
          </div>

          <div class="min-w-0">
            <h2 class="text-lg font-bold text-[#2D4BA6] dark:text-white truncate">
              Painel do Usuário
            </h2>
            <p class="text-sm text-slate-500 dark:text-white/60 truncate">
              {{#if user.nome}}{{user.nome}}{{else}}Área do usuário{{/if}}
            </p>
          </div>
        </div>
      </div>

      <nav class="p-4 flex flex-col h-full">
        <div class="space-y-2">
          <p class="px-3 text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-white/40">
            Navegação
          </p>

          <a href="/dashboard" data-nav
            class="sidebar-link flex items-center gap-3 px-4 py-3 rounded-2xl hover:bg-[#2D4BA6]/5 dark:hover:bg-white/5 text-[#2D4BA6] dark:text-white transition-all duration-200 hover:translate-x-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1h-2z" />
            </svg>
            <span class="font-medium">Dashboard</span>
          </a>

          <a href="/necessidades" data-nav
            class="sidebar-link flex items-center gap-3 px-4 py-3 rounded-2xl hover:bg-[#2D4BA6]/5 dark:hover:bg-white/5 text-[#2D4BA6] dark:text-white transition-all duration-200 hover:translate-x-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
            <span class="font-medium">Necessidades</span>
          </a>

          <a href="/ongs" data-nav
            class="sidebar-link flex items-center gap-3 px-4 py-3 rounded-2xl hover:bg-[#2D4BA6]/5 dark:hover:bg-white/5 text-[#2D4BA6] dark:text-white transition-all duration-200 hover:translate-x-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
            <span class="font-medium">Explorar ONGs</span>
          </a>

          <a href="/calendario" data-nav
            class="sidebar-link flex items-center gap-3 px-4 py-3 rounded-2xl hover:bg-[#2D4BA6]/5 dark:hover:bg-white/5 text-[#2D4BA6] dark:text-white transition-all duration-200 hover:translate-x-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <span class="font-medium">Calendário</span>
          </a>

          <a href="/mensagens" data-nav
            class="sidebar-link flex items-center gap-3 px-4 py-3 rounded-2xl hover:bg-[#2D4BA6]/5 dark:hover:bg-white/5 text-[#2D4BA6] dark:text-white transition-all duration-200 hover:translate-x-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
            <span class="font-medium">Mensagens</span>
          </a>

          <a href="/marketplace" data-nav
            class="sidebar-link flex items-center gap-3 px-4 py-3 rounded-2xl hover:bg-[#2D4BA6]/5 dark:hover:bg-white/5 text-[#2D4BA6] dark:text-white transition-all duration-200 hover:translate-x-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
            </svg>
            <span class="font-medium">Marketplace</span>
          </a>
        </div>

        <div class="mt-6">
          <p class="px-3 text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-white/40">
            Ação rápida
          </p>

          <a href="/necessidades"
            class="mt-2 flex items-center justify-center gap-2 px-4 py-3 rounded-2xl bg-gradient-to-r from-[#4886D9] to-[#2D4BA6] text-white font-semibold shadow-md hover:opacity-90 transition">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
            </svg>
            <span>Explorar necessidades</span>
          </a>
        </div>

        <div class="mt-6 space-y-2">
          <p class="px-3 text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-white/40">
            Conta
          </p>

          <a href="/perfil/editar" data-nav
            class="sidebar-link flex items-center gap-3 px-4 py-3 rounded-2xl hover:bg-[#2D4BA6]/5 dark:hover:bg-white/5 text-[#2D4BA6] dark:text-white transition-all duration-200 hover:translate-x-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            <span class="font-medium">Perfil</span>
          </a>

          <a href="/notificacoes" data-nav
            class="sidebar-link flex items-center gap-3 px-4 py-3 rounded-2xl hover:bg-[#2D4BA6]/5 dark:hover:bg-white/5 text-[#2D4BA6] dark:text-white transition-all duration-200 hover:translate-x-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6 6 0 10-12 0v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
            </svg>
            <span class="font-medium">Notificações</span>
          </a>

          <form action="/logout" method="post" class="mt-4">
          <button type="submit"
            class="flex items-center justify-center gap-2 w-full px-4 py-3 rounded-2xl bg-red-500 text-white hover:bg-red-600 transition shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
            <span class="font-medium">Sair</span>
          </button>
          </form>
        </div>
      </nav>
    </aside>

    <!-- Menu mobile Usuario -->
    <div id="mobile-menu-overlay" class="fixed inset-0 z-40 hidden lg:hidden bg-slate-950/60 backdrop-blur-sm"></div>
    <aside id="mobile-menu"
      class="fixed inset-y-0 left-0 z-50 hidden lg:hidden w-[min(20rem,calc(100vw-2rem))] flex-col bg-white dark:bg-[#102235] border-r border-slate-200 dark:border-white/10 shadow-2xl">
      <div class="px-5 py-5 border-b border-slate-200 dark:border-white/10 flex items-center justify-between gap-3">
        <div class="min-w-0">
          <p class="text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-white/40">Menu do usuario</p>
          <h2 class="text-lg font-bold text-[#2D4BA6] dark:text-white truncate">
            {{#if user.nome}}{{user.nome}}{{else}}Painel do Usuario{{/if}}
          </h2>
        </div>
        <button type="button" data-mobile-menu-close
          class="w-10 h-10 rounded-2xl bg-slate-100 dark:bg-white/10 flex items-center justify-center text-[#2D4BA6] dark:text-white">
          <span class="sr-only">Fechar menu</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <nav class="p-4 overflow-y-auto">
        <p class="px-3 mb-2 text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-white/40">Navegacao</p>
        <div class="space-y-2">
          <a href="/dashboard" data-nav class="mobile-nav-link flex items-center px-4 py-3 rounded-2xl text-[#2D4BA6] dark:text-white hover:bg-[#2D4BA6]/5 dark:hover:bg-white/5 font-medium">Dashboard</a>
          <a href="/necessidades" data-nav class="mobile-nav-link flex items-center px-4 py-3 rounded-2xl text-[#2D4BA6] dark:text-white hover:bg-[#2D4BA6]/5 dark:hover:bg-white/5 font-medium">Necessidades</a>
          <a href="/ongs" data-nav class="mobile-nav-link flex items-center px-4 py-3 rounded-2xl text-[#2D4BA6] dark:text-white hover:bg-[#2D4BA6]/5 dark:hover:bg-white/5 font-medium">Explorar ONGs</a>
<a href="/calendario" data-nav class="mobile-nav-link flex items-center px-4 py-3 rounded-2xl text-[#2D4BA6] dark:text-white hover:bg-[#2D4BA6]/5 dark:hover:bg-white/5 font-medium">Calendário</a>
          <a href="/mensagens" data-nav class="mobile-nav-link flex items-center px-4 py-3 rounded-2xl text-[#2D4BA6] dark:text-white hover:bg-[#2D4BA6]/5 dark:hover:bg-white/5 font-medium">Mensagens</a>
          <a href="/marketplace" data-nav class="mobile-nav-link flex items-center px-4 py-3 rounded-2xl text-[#2D4BA6] dark:text-white hover:bg-[#2D4BA6]/5 dark:hover:bg-white/5 font-medium">Marketplace</a>
        </div>

        <p class="px-3 mt-6 mb-2 text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-white/40">Acao rapida</p>
        <a href="/necessidades" class="flex items-center justify-center px-4 py-3 rounded-2xl bg-gradient-to-r from-[#4886D9] to-[#2D4BA6] text-white font-semibold shadow-md">Explorar necessidades</a>

        <p class="px-3 mt-6 mb-2 text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-white/40">Conta</p>
        <div class="space-y-2">
          <a href="/perfil/editar" data-nav class="mobile-nav-link flex items-center px-4 py-3 rounded-2xl text-[#2D4BA6] dark:text-white hover:bg-[#2D4BA6]/5 dark:hover:bg-white/5 font-medium">Perfil</a>
          <a href="/notificacoes" data-nav class="mobile-nav-link flex items-center px-4 py-3 rounded-2xl text-[#2D4BA6] dark:text-white hover:bg-[#2D4BA6]/5 dark:hover:bg-white/5 font-medium">Notificacoes</a>
          <form action="/logout" method="post">
            <button type="submit" class="flex w-full items-center justify-center px-4 py-3 rounded-2xl bg-red-500 text-white font-medium shadow-sm">Sair</button>
          </form>
        </div>
      </nav>
    </aside>

    <!-- Conteúdo -->
    <main class="flex-1 min-w-0 flex flex-col">

      <!-- Topbar -->
      <header
        class="sticky top-0 z-30 bg-white/90 dark:bg-[#0D1B2A]/90 backdrop-blur border-b border-slate-200 dark:border-white/10">
        <div class="px-4 sm:px-6 py-4 flex items-start sm:items-center justify-between gap-3">
          <button type="button" data-mobile-menu-open
            class="lg:hidden flex items-center justify-center w-10 h-10 rounded-2xl bg-slate-100 dark:bg-white/10 text-[#2D4BA6] dark:text-white shadow-sm shrink-0">
            <span class="sr-only">Abrir menu</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
          <div class="min-w-0">
            <h1 class="text-xl sm:text-2xl font-bold text-[#2D4BA6] dark:text-white truncate">
              {{#if title}}{{title}}{{else}}Dashboard{{/if}}
            </h1>
            <p class="hidden sm:block text-sm text-slate-500 dark:text-white/60">
              Acompanhe interesses, necessidades e seu impacto.
            </p>
          </div>

          <div class="flex items-center gap-2 sm:gap-3 shrink-0">
            <div class="hidden sm:flex items-center gap-3 px-3 py-2 rounded-2xl bg-slate-100 dark:bg-white/10">
              <div
                class="w-9 h-9 rounded-xl bg-gradient-to-br from-[#4886D9] to-[#2D4BA6] flex items-center justify-center text-white text-sm font-bold">
                {{#if user.nome}}{{user.nome.[0]}}{{else}}U{{/if}}
              </div>
              <div class="leading-tight">
                <p class="text-sm font-semibold text-[#2D4BA6] dark:text-white">
                  {{#if user.nome}}{{user.nome}}{{else}}Usuário{{/if}}
                </p>
                <p class="text-xs text-slate-500 dark:text-white/60">
                  Conta pessoal
                </p>
              </div>
            </div>

            <a href="/notificacoes"
              class="relative flex items-center justify-center w-10 h-10 rounded-2xl bg-slate-100 dark:bg-white/10 hover:opacity-90 shadow-sm transition"
              title="Notificações">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[#2D4BA6] dark:text-white" fill="none"
                viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6 6 0 10-12 0v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
              </svg>
              {{#if naoLidas}}
              <span
                class="absolute -top-1 -right-1 min-w-[1.1rem] h-[1.1rem] px-1 rounded-full bg-red-500 text-white text-[10px] font-bold flex items-center justify-center">
                {{naoLidas}}
              </span>
              {{/if}}
            </a>

            <button id="toggle-theme" type="button"
              class="flex items-center justify-center w-10 h-10 rounded-2xl bg-[#2D4BA6] text-white dark:bg-white dark:text-[#2D4BA6] hover:opacity-90 shadow-sm transition">
              <!-- Lua -->
              <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24"
                stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
              </svg>

              <!-- Sol -->
              <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 hidden" fill="none"
                viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M12 3v2m0 14v2m9-9h-2M5 12H3m15.364 6.364l-1.414-1.414M6.05 6.05 4.636 4.636m12.728 0l-1.414 1.414M6.05 17.95l-1.414 1.414M12 8a4 4 0 100 8 4 4 0 000-8z" />
              </svg>
            </button>
          </div>
        </div>
      </header>

      <!-- Conteúdo da página -->
      <div class="flex-1 min-w-0 max-w-full overflow-x-hidden px-4 sm:px-6 py-6">
        {{{body}}}
      </div>

      <div class="px-4 sm:px-6 pb-4">
        {{> apoiadoresRodape}}
      </div>

    </main>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const html = document.documentElement;
      const toggle = document.getElementById('toggle-theme');
      const iconMoon = document.getElementById('icon-moon');
      const iconSun = document.getElementById('icon-sun');

      function updateIcon(theme) {
        if (!iconMoon || !iconSun) return;

        if (theme === 'dark') {
          iconMoon.classList.add('hidden');
          iconSun.classList.remove('hidden');
        } else {
          iconMoon.classList.remove('hidden');
          iconSun.classList.add('hidden');
        }
      }

      function applyTheme(theme) {
        if (theme === 'dark') html.classList.add('dark');
        else html.classList.remove('dark');

        localStorage.setItem('theme', theme);
        updateIcon(theme);
      }

      const saved = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      applyTheme(saved || (prefersDark ? 'dark' : 'light'));

      if (toggle) {
        toggle.addEventListener('click', () => {
          const next = html.classList.contains('dark') ? 'light' : 'dark';
          applyTheme(next);
          window.dispatchEvent(new Event('theme:changed'));
        });
      }

      const mobileMenu = document.getElementById('mobile-menu');
      const mobileOverlay = document.getElementById('mobile-menu-overlay');
      const openMobileMenu = document.querySelector('[data-mobile-menu-open]');
      const closeMobileMenu = document.querySelector('[data-mobile-menu-close]');

      function setMobileMenu(open) {
        if (!mobileMenu || !mobileOverlay) return;
        mobileMenu.classList.toggle('hidden', !open);
        mobileMenu.classList.toggle('flex', open);
        mobileOverlay.classList.toggle('hidden', !open);
        document.body.classList.toggle('overflow-hidden', open);
      }

      if (openMobileMenu) openMobileMenu.addEventListener('click', () => setMobileMenu(true));
      if (closeMobileMenu) closeMobileMenu.addEventListener('click', () => setMobileMenu(false));
      if (mobileOverlay) mobileOverlay.addEventListener('click', () => setMobileMenu(false));

      // Sidebar: destacar link ativo (match mais específico)
      var path = window.location.pathname;
      var links = document.querySelectorAll('a.sidebar-link[data-nav], a.mobile-nav-link[data-nav]');
      var bestLink = null, bestLen = 0;
      links.forEach(function(link) {
        var href = link.getAttribute('href');
        if (path === href || (href !== '/' && path.startsWith(href))) {
          if (href.length > bestLen) { bestLen = href.length; bestLink = link; }
        }
      });
      if (bestLink) {
        bestLink.classList.add('bg-[#2D4BA6]/10', 'dark:bg-[#4886D9]/15', 'font-semibold', 'border-l-4', 'border-[#4886D9]');
        bestLink.classList.remove('hover:translate-x-0.5');
      }
    });
  </script>
</body>

</html>
