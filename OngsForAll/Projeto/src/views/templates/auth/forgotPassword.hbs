<section class="flex text-gray-700 flex-col justify-center h-screen items-center">
  <form action="/esqueci-minha-senha" method="POST" class="bg-white p-6 rounded-lg shadow-md w-96 text-center">
    <h2 class="text-2xl font-bold mb-4 flex items-center justify-center gap-2 text-[#1D3273]">
      <span>🔒</span> Recuperar Senha
    </h2>
    {{#if error}}
    <p class="text-red-500 text-sm text-center mb-2">{{error}}</p>
    {{/if}}

    <div class="text-left space-y-4">
      <div>
        <label for="nome" class="font-medium">Nome completo:</label>
        <input type="text" id="nome" name="nome" required
          class="w-full border p-2 rounded focus:outline-none focus:ring focus:border-blue-400" />
      </div>

      <div>
        <label for="email" class="font-medium">E-mail:</label>
        <input type="email" id="email" name="email" required placeholder="email@exemplo.com"
          class="w-full border p-2 rounded focus:outline-none focus:ring focus:border-blue-400" />
      </div>

      <div>
        <label for="cpf" class="font-medium">CPF:</label>
        <input type="text" id="cpf" name="cpf" required placeholder="000.000.000-00"
          class="w-full border p-2 rounded focus:outline-none focus:ring focus:border-blue-400" />
      </div>
    </div>

    <button type="submit"
      class="w-full mt-6 bg-[#1D3273] hover:bg-[#1D3273]/90 text-white font-semibold py-2 rounded transition">
      Enviar
    </button>

    <a href="/login" class="block mt-4 text-sm text-[#1D3273] hover:underline">← Voltar para o login</a>
  </form>
</section>
<script>
  const cpfInput = document.getElementById('cpf');
  if (cpfInput) {
    cpfInput.addEventListener('input', function (e) {
      let value = e.target.value.replace(/\D/g, '');
      if (value.length = 11) value = value.slice(0, 11);
      value = value.replace(/(\d{3})(\d)/, '$1.$2');
      value = value.replace(/(\d{3})(\d)/, '$1.$2');
      value = value.replace(/(\d{3})(\d{1,2})$/, '$1-$2');
      e.target.value = value;
    });
  }
</script>