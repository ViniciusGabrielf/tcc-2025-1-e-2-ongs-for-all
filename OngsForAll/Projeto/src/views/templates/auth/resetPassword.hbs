<div class="flex flex-col items-center justify-center min-h-screen py-10 px-4">
  <div class="w-full max-w-lg bg-white dark:bg-[#102235] rounded-2xl shadow-lg border border-slate-200 dark:border-white/10 p-6 sm:p-8">

    <div class="text-center mb-8">
      <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-violet-500 to-purple-700 flex items-center justify-center mx-auto mb-4 shadow-md">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
      </div>
      <a href="/login" class="inline-flex items-center gap-2 text-sm font-semibold text-slate-500 dark:text-white/50 hover:text-violet-600 dark:hover:text-violet-400 transition mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Voltar para o login
      </a>
      <h1 class="text-2xl font-bold text-[#2D4BA6] dark:text-white">Redefinir Senha</h1>
      <p class="text-sm text-slate-500 dark:text-white/50 mt-1">Insira o código recebido por e-mail e defina sua nova senha</p>
    </div>

    {{#if emailEnviado}}
    <div class="mb-5 px-4 py-3 rounded-xl bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 text-green-700 dark:text-green-300 text-sm">
      Código enviado! Verifique sua caixa de entrada (e a pasta de spam) e insira o código abaixo.
    </div>
    {{/if}}

    {{#if error}}
    <div class="mb-5 px-4 py-3 rounded-xl bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-300 text-sm">
      {{error}}
    </div>
    {{/if}}

    {{#if success}}
    <div class="mb-5 px-4 py-3 rounded-xl bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 text-green-700 dark:text-green-300 text-sm">
      {{success}}
    </div>
    {{/if}}

    <form id="resetForm" action="/redefinir-senha" method="POST" class="space-y-4">

      <div>
        <label for="codigo" class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">Código recebido por e-mail</label>
        <input
          type="text"
          name="codigo"
          id="codigo"
          required
          maxlength="6"
          inputmode="numeric"
          pattern="[0-9]{6}"
          placeholder="000000"
          class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-violet-400 text-center text-2xl tracking-widest font-mono"
        />
      </div>

      <div>
        <label for="password" class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">Nova senha</label>
        <input
          type="password"
          name="password"
          id="password"
          required
          minlength="8"
          placeholder="Digite a nova senha"
          class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-violet-400"
        />
        <ul id="hints-reset" class="mt-2 space-y-0.5 text-xs hidden">
          <li data-rule="length"  class="flex items-center gap-1.5 text-slate-400 dark:text-white/40"><span class="indicator font-bold">○</span> Mínimo 8 caracteres</li>
          <li data-rule="upper"   class="flex items-center gap-1.5 text-slate-400 dark:text-white/40"><span class="indicator font-bold">○</span> Letra maiúscula</li>
          <li data-rule="lower"   class="flex items-center gap-1.5 text-slate-400 dark:text-white/40"><span class="indicator font-bold">○</span> Letra minúscula</li>
          <li data-rule="number"  class="flex items-center gap-1.5 text-slate-400 dark:text-white/40"><span class="indicator font-bold">○</span> Número</li>
          <li data-rule="special" class="flex items-center gap-1.5 text-slate-400 dark:text-white/40"><span class="indicator font-bold">○</span> Caractere especial (ex.: . ! @)</li>
        </ul>
      </div>

      <div>
        <label for="confirmarSenha" class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">Confirmar nova senha</label>
        <input
          type="password"
          name="confirmarSenha"
          id="confirmarSenha"
          required
          minlength="6"
          placeholder="Confirme a nova senha"
          class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-violet-400"
        />
      </div>

      <div id="clientError" class="hidden px-4 py-3 rounded-xl bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-300 text-sm"></div>

      <button
        type="submit"
        class="w-full py-3 rounded-2xl bg-gradient-to-r from-violet-500 to-purple-700 text-white font-bold text-sm shadow-md hover:opacity-90 transition mt-2">
        Redefinir Senha
      </button>
    </form>

  </div>
</div>

<script>
  const form = document.getElementById("resetForm");
  const pass = document.getElementById("password");
  const confirm = document.getElementById("confirmarSenha");
  const clientError = document.getElementById("clientError");
  const hintsReset = document.getElementById("hints-reset");

  const pwdRules = {
    length:  v => v.length >= 8,
    upper:   v => /[A-Z]/.test(v),
    lower:   v => /[a-z]/.test(v),
    number:  v => /\d/.test(v),
    special: v => /[^A-Za-z0-9]/.test(v),
  };

  pass.addEventListener('focus', () => hintsReset.classList.remove('hidden'));
  pass.addEventListener('input', () => {
    const v = pass.value;
    hintsReset.querySelectorAll('li').forEach(li => {
      const ok = pwdRules[li.dataset.rule](v);
      li.querySelector('.indicator').textContent = ok ? '✓' : '○';
      li.classList.toggle('text-green-500', ok);
      li.classList.toggle('dark:text-green-400', ok);
      li.classList.toggle('text-slate-400', !ok);
      li.classList.toggle('dark:text-white/40', !ok);
    });
  });

  const SENHA_REGEX = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^A-Za-z0-9]).{8,}$/;

  form.addEventListener("submit", (e) => {
    clientError.classList.add("hidden");
    clientError.textContent = "";

    if (!SENHA_REGEX.test(pass.value)) {
      e.preventDefault();
      clientError.textContent = "A senha deve ter no mínimo 8 caracteres, incluindo letra maiúscula, minúscula, número e caractere especial (ex.: . ! @ #).";
      clientError.classList.remove("hidden");
      pass.focus();
      return;
    }

    if (pass.value !== confirm.value) {
      e.preventDefault();
      clientError.textContent = "As senhas não coincidem.";
      clientError.classList.remove("hidden");
      confirm.focus();
    }
  });
</script>
