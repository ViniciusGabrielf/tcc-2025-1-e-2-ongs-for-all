<section class="flex text-gray-700 flex-col justify-center h-screen items-center">
  <div class="w-full max-w-md bg-white text-[#1D3273] p-6 sm:p-8 rounded-xl shadow-md">
    <h2 class="text-center text-2xl font-bold mb-6 flex items-center justify-center gap-2">
      🔐 Redefinir Senha
    </h2>

    {{#if emailEnviado}}
      <div class="mb-4 text-sm text-green-700 bg-green-50 p-3 rounded-lg">
        Código enviado para o seu e-mail! Verifique sua caixa de entrada (e a pasta de spam) e insira o código abaixo.
      </div>
    {{/if}}

    {{#if error}}
      <div class="mb-4 text-sm text-red-700 bg-red-50 p-3 rounded-lg">
        {{error}}
      </div>
    {{/if}}

    {{#if success}}
      <div class="mb-4 text-sm text-green-700 bg-green-50 p-3 rounded-lg">
        {{success}}
      </div>
    {{/if}}

    <form id="resetForm" action="/redefinir-senha" method="POST">
      <div class="mb-4">
        <label for="codigo" class="block font-semibold mb-1">Código recebido por e-mail:</label>
        <input
          type="text"
          name="codigo"
          id="codigo"
          required
          maxlength="6"
          inputmode="numeric"
          pattern="[0-9]{6}"
          placeholder="000000"
          class="w-full px-4 py-2 rounded border border-gray-300 focus:outline-none focus:ring-2 focus:ring-[#1D3273] text-center text-2xl tracking-widest font-mono"
        />
      </div>

      <div>
        <label for="password" class="block font-semibold mb-1">Nova senha:</label>
        <input
          type="password"
          name="password"
          id="password"
          required
          minlength="6"
          placeholder="Digite a nova senha"
          class="w-full px-4 py-2 rounded border border-gray-300 focus:outline-none focus:ring-2 focus:ring-[#1D3273]"
        />
      </div>

      <div class="mt-4">
        <label for="confirmarSenha" class="block font-semibold mb-1">Confirmar senha:</label>
        <input
          type="password"
          name="confirmarSenha"
          id="confirmarSenha"
          required
          minlength="6"
          placeholder="Confirme a nova senha"
          class="w-full px-4 py-2 rounded border border-gray-300 focus:outline-none focus:ring-2 focus:ring-[#1D3273]"
        />
      </div>

      <p id="clientError" class="hidden mt-3 text-sm text-red-700 bg-red-50 p-3 rounded-lg"></p>

      <button
        type="submit"
        class="w-full mt-4 bg-[#1D3273] hover:bg-[#27428b] text-white font-semibold py-2 rounded transition-all"
      >
        Redefinir Senha
      </button>
    </form>

    <div class="text-center mt-4">
      <a href="/login" class="text-sm text-[#1D3273] underline hover:text-blue-600">Voltar ao login</a>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("resetForm");
  const pass = document.getElementById("password");
  const confirm = document.getElementById("confirmarSenha");
  const clientError = document.getElementById("clientError");

  form.addEventListener("submit", (e) => {
    clientError.classList.add("hidden");
    clientError.textContent = "";

    if (pass.value !== confirm.value) {
      e.preventDefault();
      clientError.textContent = "As senhas não coincidem.";
      clientError.classList.remove("hidden");
      confirm.focus();
    }
  });
</script>
