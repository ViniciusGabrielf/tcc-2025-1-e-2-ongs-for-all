<div class="flex flex-col items-center justify-center min-h-screen py-10 px-4">
  <div class="w-full max-w-lg bg-white dark:bg-[#102235] rounded-2xl shadow-lg border border-slate-200 dark:border-white/10 p-6 sm:p-8">

    <div class="text-center mb-8">
      <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-violet-500 to-purple-700 flex items-center justify-center mx-auto mb-4 shadow-md">
        <box-icon color="#ffffff" name="log-in-circle"></box-icon>
      </div>
      <h1 class="text-2xl font-bold text-[#2D4BA6] dark:text-white">Entrar na ONG For All</h1>
      <p class="text-sm text-slate-500 dark:text-white/50 mt-1">Acesse sua conta para acompanhar doações, ONGs e oportunidades de apoio</p>
    </div>

    {{#if resetSuccess}}
    <div id="toast-reset"
      class="fixed top-6 right-6 z-50 max-w-sm bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-xl shadow-lg flex items-start gap-3">
      <span class="text-lg">✅</span>
      <div class="text-sm">
        <p class="font-semibold">Senha alterada com sucesso</p>
        <p class="opacity-80">Faça login com sua nova senha.</p>
      </div>
    </div>

    <script>
      (function () {
        const el = document.getElementById("toast-reset");
        if (!el) return;

        setTimeout(() => {
          el.classList.add("opacity-0");
          el.classList.add("transition-opacity");
          el.classList.add("duration-500");
        }, 3000);

        setTimeout(() => {
          el.remove();
        }, 3600);

        if (window.history && window.history.replaceState) {
          const url = new URL(window.location.href);
          url.searchParams.delete("reset");
          window.history.replaceState({}, document.title, url.toString());
        }
      })();
    </script>
    {{/if}}

    {{#if logoutSuccess}}
    <div class="mb-5 px-4 py-3 rounded-xl bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 text-green-700 dark:text-green-300 text-sm">
      Você saiu com sucesso.
    </div>
    {{/if}}

    {{#if error}}
    <div class="mb-5 px-4 py-3 rounded-xl bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-300 text-sm">
      {{error}}
    </div>
    {{/if}}

    <form action="/login" method="POST" class="space-y-4">
      {{#if redirectTo}}
      <input type="hidden" name="redirect" value="{{redirectTo}}" />
      {{/if}}

      <div>
        <label for="email" class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">Email</label>
        <input
          class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-violet-400"
          type="email"
          name="email"
          id="email"
          value="{{email}}"
          placeholder="email@email.com"
          required
        />
      </div>

      <div>
        <label for="password" class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">Senha</label>
        <input
          class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-violet-400"
          type="password"
          name="password"
          id="password"
          placeholder="************"
          required
        />
      </div>

      <div class="text-right">
        <a href="/esqueci-minha-senha" class="text-sm text-violet-600 dark:text-violet-400 font-medium hover:underline">Esqueceu sua senha?</a>
      </div>

      <button
        class="w-full py-3 rounded-2xl bg-gradient-to-r from-violet-500 to-purple-700 text-white font-bold text-sm shadow-md hover:opacity-90 transition mt-2"
        type="submit">
        Entrar
      </button>
    </form>

    <p class="text-center text-sm text-slate-500 dark:text-white/50 mt-5">
      Não tem uma conta?
      <a href="{{registerUrl}}" class="text-violet-600 dark:text-violet-400 font-semibold hover:underline">Cadastre-se</a>
    </p>
  </div>
</div>
