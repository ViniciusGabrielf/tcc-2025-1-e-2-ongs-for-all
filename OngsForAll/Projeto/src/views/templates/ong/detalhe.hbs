<section class="min-h-screen {{#unless user}}pt-28 px-4 sm:px-6 pb-10{{/unless}}">
  <div class="max-w-3xl mx-auto space-y-6">

    {{! Navegação }}
    <div>
      <a href="/ongs" class="inline-flex items-center gap-1.5 text-sm text-slate-500 dark:text-white/50 hover:text-[#6B8F71] dark:hover:text-white transition mb-3">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Explorar ONGs
      </a>
    </div>

    {{! ONG não encontrada }}
    {{#unless ong}}
    <div class="bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-2xl p-12 shadow-sm text-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 mx-auto text-slate-300 dark:text-white/20 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <h2 class="text-xl font-bold text-slate-500 dark:text-white/50 mb-2">ONG não encontrada</h2>
      <p class="text-slate-400 dark:text-white/40">Esta ONG não existe ou foi removida.</p>
    </div>
    {{/unless}}

    {{#if ong}}

    {{! Mensagem de sucesso }}
    {{#if sucesso}}
    <div class="flex items-start gap-3 px-4 py-3 rounded-xl bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800/40 text-sm text-green-700 dark:text-green-300">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <span>Sua avaliação foi registrada com sucesso! Você pode alterar sua avaliação a qualquer momento.</span>
    </div>
    {{/if}}

    {{! Mensagem de erro }}
    {{#if erro}}
    <div class="flex items-start gap-3 px-4 py-3 rounded-xl bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800/40 text-sm text-red-700 dark:text-red-300">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <span>{{erro}}</span>
    </div>
    {{/if}}

    {{! Card da ONG }}
    <div class="bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-2xl shadow-sm overflow-hidden">
      <div class="h-24 bg-gradient-to-r from-[#6B8F71] to-[#2F3E34]"></div>
      <div class="px-6 pb-6">
        <div class="-mt-10 mb-4">
          {{#if ong.logo}}
          <img src="{{ong.logo}}" alt="Logo de {{ong.nome}}"
            class="w-20 h-20 rounded-2xl object-cover border-4 border-white dark:border-[#0D1B2A] shadow-md bg-white dark:bg-[#102235]" />
          {{else}}
          <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-[#6B8F71] to-[#2F3E34] flex items-center justify-center text-white text-2xl font-bold border-4 border-white dark:border-[#0D1B2A] shadow-md">
            {{ong.nome.[0]}}
          </div>
          {{/if}}
        </div>

        <h1 class="text-2xl font-extrabold text-[#2F3E34] dark:text-white">{{ong.nome}}</h1>

        {{#if ong.area_atuacao}}
        <span class="inline-block mt-2 px-3 py-1 rounded-full bg-[#6B8F71]/10 dark:bg-[#6B8F71]/20 text-[#2F3E34] dark:text-[#EAF3EC] text-xs font-semibold">
          {{ong.area_atuacao}}
        </span>
        {{/if}}

        <div class="mt-4 space-y-2">
          {{#if ong.email}}
          <div class="flex items-center gap-2 text-sm text-slate-500 dark:text-white/50">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <span>{{ong.email}}</span>
          </div>
          {{/if}}
          {{#if ong.telefone}}
          <div class="flex items-center gap-2 text-sm text-slate-500 dark:text-white/50">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <span>{{ong.telefone}}</span>
          </div>
          {{/if}}
          {{#if ong.cidade}}
          <div class="flex items-center gap-2 text-sm text-slate-500 dark:text-white/50">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>{{ong.cidade}}{{#if ong.estado}}, {{ong.estado}}{{/if}}</span>
          </div>
          {{/if}}
        </div>

        <div class="mt-5 flex flex-wrap gap-2">
          <a href="/necessidades?ong={{ong.id}}"
            class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-gradient-to-r from-[#6B8F71] to-[#2F3E34] text-white text-sm font-semibold shadow-sm hover:opacity-90 transition">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
            Apoiar esta ONG
          </a>
          <a href="/ongs/{{ong.id}}/localizacao"
            class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full border border-slate-200 dark:border-white/15 text-slate-600 dark:text-white/70 text-sm font-semibold hover:bg-slate-50 dark:hover:bg-white/5 transition">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Localização
          </a>
        </div>
      </div>
    </div>

    {{! Seção de avaliações }}
    <div class="bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-2xl shadow-sm p-6 space-y-6">

      <h2 class="text-lg font-bold text-[#2F3E34] dark:text-white flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
        Avaliações
      </h2>

      {{! Nota média }}
      {{#if reviews.total}}
      <div class="flex items-center gap-5">
        <div class="text-5xl font-extrabold text-[#2F3E34] dark:text-white leading-none">
          {{reviews.mediaFormatada}}
        </div>
        <div>
          <div class="flex items-center gap-0.5" aria-label="Média de {{reviews.mediaFormatada}} de 5 estrelas">
            {{#each (array 1 2 3 4 5)}}
            {{#ifCond this '<=' ../reviews.mediaArredondada}}
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
            {{else}}
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-slate-300 dark:text-white/20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
            </svg>
            {{/ifCond}}
            {{/each}}
          </div>
          <p class="text-sm text-slate-500 dark:text-white/50 mt-1">
            Baseado em {{reviews.total}} avalia{{#ifCond reviews.total '>' 1}}ções{{else}}ção{{/ifCond}}
          </p>
        </div>
      </div>
      {{else}}
      <p class="text-sm text-slate-500 dark:text-white/50 italic">
        Esta ONG ainda não possui avaliações. Seja o primeiro a avaliar!
      </p>
      {{/if}}

      {{! Formulário de avaliação (usuário logado e pode avaliar) }}
      {{#if podeAvaliar}}
      <div class="pt-5 border-t border-slate-100 dark:border-white/10">
        <h3 class="font-semibold text-slate-700 dark:text-white/80 mb-1">
          {{#if reviews.userJaAvaliou}}Alterar sua avaliação{{else}}Avaliar esta ONG{{/if}}
        </h3>
        {{#if reviews.userJaAvaliou}}
        <p class="text-xs text-slate-400 dark:text-white/40 mb-4">Você pode alterar sua avaliação a qualquer momento.</p>
        {{else}}
        <p class="text-xs text-slate-400 dark:text-white/40 mb-4">Selecione de 1 a 5 estrelas e clique em enviar.</p>
        {{/if}}

        <form method="POST" action="/ongs/{{ong.id}}/avaliar" id="review-form">
          <div class="star-rating flex items-center gap-1 mb-4" role="group" aria-label="Selecione a nota">
            {{#each (array 1 2 3 4 5)}}
            <label class="cursor-pointer" title="{{this}} estrela{{#ifCond this '>' 1}}s{{/ifCond}}" aria-label="{{this}} estrela{{#ifCond this '>' 1}}s{{/ifCond}}">
              <input type="radio" name="rating" value="{{this}}" class="sr-only"
                {{#ifCond this '===' ../reviews.userRating}}checked{{/ifCond}} />
              <svg class="star-icon w-10 h-10 transition-colors duration-100 {{#ifCond this '<=' ../reviews.userRating}}text-yellow-400{{else}}text-slate-300 dark:text-white/20{{/ifCond}}"
                xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            </label>
            {{/each}}
          </div>

          <div class="mb-5">
            <label for="review-comment" class="block text-sm font-medium text-slate-700 dark:text-white/70 mb-1.5">
              Conte o motivo da sua avaliação
              <span class="font-normal text-slate-400 dark:text-white/30">(opcional)</span>
            </label>
            <textarea
              id="review-comment"
              name="comment"
              rows="3"
              maxlength="500"
              placeholder="Exemplo: A ONG respondeu rapidamente, passou confiança e explicou bem como a doação será usada."
              class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-white/10 bg-white dark:bg-white/5 text-slate-900 dark:text-white text-sm resize-none focus:outline-none focus:ring-2 focus:ring-[#6B8F71]/40 placeholder:text-slate-400 dark:placeholder:text-white/30 transition"
            >{{#if reviews.userComment}}{{reviews.userComment}}{{/if}}</textarea>
            <div class="flex justify-between mt-1.5">
              <p class="text-xs text-slate-400 dark:text-white/30">
                Sua observação ajuda outros usuários a entender melhor sua experiência.
              </p>
              <span class="text-xs text-slate-400 dark:text-white/30 shrink-0 ml-2" id="comment-counter">0/500</span>
            </div>
          </div>

          <button type="submit"
            class="inline-flex items-center gap-2 px-6 py-2.5 rounded-full bg-gradient-to-r from-[#6B8F71] to-[#2F3E34] text-white text-sm font-semibold shadow-sm hover:opacity-90 transition">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            {{#if reviews.userJaAvaliou}}Atualizar avaliação{{else}}Enviar avaliação{{/if}}
          </button>
        </form>
      </div>
      {{/if}}

      {{! Usuário logado mas é ONG — não pode avaliar }}
      {{#if user}}
      {{#ifCond user.tipo '===' 'ong'}}
      <div class="pt-5 border-t border-slate-100 dark:border-white/10">
        <p class="text-sm text-slate-400 dark:text-white/40 italic">Contas do tipo ONG não podem avaliar outras ONGs.</p>
      </div>
      {{/ifCond}}
      {{/if}}

      {{! Usuário não autenticado }}
      {{#unless user}}
      <div class="pt-5 border-t border-slate-100 dark:border-white/10 flex items-center gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-400 dark:text-white/30 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
        <p class="text-sm text-slate-500 dark:text-white/50">
          <a href="/login?redirect={{loginRedirectUrl}}" class="font-semibold text-[#6B8F71] hover:underline">Faça login</a>
          para avaliar esta ONG.
        </p>
      </div>
      {{/unless}}

    </div>

    {{/if}}
  </div>
</section>

<script>
(function () {
  var form = document.getElementById('review-form');
  if (!form) return;

  var container = form.querySelector('.star-rating');
  if (!container) return;

  var inputs = Array.from(container.querySelectorAll('input[type="radio"]'));
  var icons  = Array.from(container.querySelectorAll('.star-icon'));

  function fillStars(count) {
    icons.forEach(function (icon, i) {
      if (i < count) {
        icon.classList.add('text-yellow-400');
        icon.classList.remove('text-slate-300', 'dark:text-white/20');
      } else {
        icon.classList.remove('text-yellow-400');
        icon.classList.add('text-slate-300');
      }
    });
  }

  function getCheckedValue() {
    var checked = container.querySelector('input[type="radio"]:checked');
    return checked ? parseInt(checked.value, 10) : 0;
  }

  icons.forEach(function (icon, idx) {
    icon.addEventListener('mouseover', function () {
      fillStars(idx + 1);
    });
    icon.addEventListener('mouseout', function () {
      fillStars(getCheckedValue());
    });
    icon.addEventListener('click', function () {
      inputs[idx].checked = true;
      fillStars(idx + 1);
    });
  });

  inputs.forEach(function (input, idx) {
    input.addEventListener('change', function () {
      fillStars(idx + 1);
    });
    input.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') {
        input.checked = true;
        fillStars(idx + 1);
      }
    });
  });

  // Contador de caracteres do textarea
  var textarea = form.querySelector('textarea[name="comment"]');
  var counter  = document.getElementById('comment-counter');
  if (textarea && counter) {
    function updateCounter() {
      var len = textarea.value.length;
      counter.textContent = len + '/500';
      counter.classList.toggle('text-red-400', len >= 480);
      counter.classList.toggle('dark:text-red-400', len >= 480);
    }
    updateCounter();
    textarea.addEventListener('input', updateCounter);
  }
})();
</script>
