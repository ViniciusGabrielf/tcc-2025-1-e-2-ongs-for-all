<div class="max-w-5xl mx-auto space-y-6">

  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
    <div>
      <h2 class="text-2xl font-bold text-[#2F3E34] dark:text-white">Interesses recebidos</h2>
      <p class="text-sm text-slate-500 dark:text-white/60 mt-0.5">Gerencie os interesses de usuarios nas suas necessidades</p>
    </div>

    <form method="GET" action="/ong/interesses" class="flex flex-col sm:flex-row gap-3 w-full md:w-auto">
      <input type="text" name="busca" value="{{buscaAtual}}" placeholder="Buscar por ID ou nome do usuario"
        class="min-w-[260px] px-3 py-2 rounded-xl border border-slate-200 dark:border-white/10 bg-white dark:bg-white/5 text-slate-900 dark:text-white text-sm placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-[#6B8F71] transition" />
      <select name="status" onchange="this.form.submit()"
        class="px-3 py-2 rounded-xl border border-slate-200 dark:border-white/10 bg-white dark:bg-white/5 dark:[color-scheme:dark] text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-[#6B8F71] transition">
        <option value="pendente" {{#ifCond filtroAtual 'pendente'}}selected{{/ifCond}}>Pendentes</option>
        <option value="aceito" {{#ifCond filtroAtual 'aceito'}}selected{{/ifCond}}>Aceitos</option>
        <option value="recebido" {{#ifCond filtroAtual 'recebido'}}selected{{/ifCond}}>Recebidos</option>
        <option value="cancelado" {{#ifCond filtroAtual 'cancelado'}}selected{{/ifCond}}>Cancelados</option>
        <option value="todos" {{#ifCond filtroAtual 'todos'}}selected{{/ifCond}}>Todos</option>
      </select>
      <button type="submit"
        class="px-4 py-2 rounded-xl bg-gradient-to-r from-[#6B8F71] to-[#2F3E34] text-white text-sm font-semibold hover:opacity-90 transition shadow-sm">
        Buscar
      </button>
    </form>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-5 gap-4">
    <a href="{{resumoLinks.todos}}" class="block rounded-2xl border p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md {{#ifCond filtroAtual 'todos'}}border-[#6B8F71] bg-[#EAF3EC] dark:bg-[#6B8F71]/20{{else}}border-slate-200 dark:border-white/10 bg-white dark:bg-white/5{{/ifCond}}">
      <p class="text-xs font-semibold text-slate-400 dark:text-white/50">Total</p>
      <p class="mt-2 text-3xl font-bold text-[#2F3E34] dark:text-white">{{resumoInteresses.total}}</p>
    </a>
    <a href="{{resumoLinks.pendente}}" class="block rounded-2xl border p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md {{#ifCond filtroAtual 'pendente'}}border-[#6B8F71] bg-[#EAF3EC] dark:bg-[#6B8F71]/20{{else}}border-slate-200 dark:border-white/10 bg-white dark:bg-white/5{{/ifCond}}">
      <p class="text-xs font-semibold text-slate-400 dark:text-white/50">Pendentes</p>
      <p class="mt-2 text-3xl font-bold text-[#2F3E34] dark:text-white">{{resumoInteresses.pendentes}}</p>
    </a>
    <a href="{{resumoLinks.aceito}}" class="block rounded-2xl border p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md {{#ifCond filtroAtual 'aceito'}}border-[#6B8F71] bg-[#EAF3EC] dark:bg-[#6B8F71]/20{{else}}border-slate-200 dark:border-white/10 bg-white dark:bg-white/5{{/ifCond}}">
      <p class="text-xs font-semibold text-slate-400 dark:text-white/50">Aceitos</p>
      <p class="mt-2 text-3xl font-bold text-[#2F3E34] dark:text-white">{{resumoInteresses.aceitos}}</p>
    </a>
    <a href="{{resumoLinks.recebido}}" class="block rounded-2xl border p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md {{#ifCond filtroAtual 'recebido'}}border-[#6B8F71] bg-[#EAF3EC] dark:bg-[#6B8F71]/20{{else}}border-slate-200 dark:border-white/10 bg-white dark:bg-white/5{{/ifCond}}">
      <p class="text-xs font-semibold text-slate-400 dark:text-white/50">Recebidos</p>
      <p class="mt-2 text-3xl font-bold text-[#2F3E34] dark:text-white">{{resumoInteresses.recebidos}}</p>
    </a>
    <a href="{{resumoLinks.cancelado}}" class="block rounded-2xl border p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md {{#ifCond filtroAtual 'cancelado'}}border-[#6B8F71] bg-[#EAF3EC] dark:bg-[#6B8F71]/20{{else}}border-slate-200 dark:border-white/10 bg-white dark:bg-white/5{{/ifCond}}">
      <p class="text-xs font-semibold text-slate-400 dark:text-white/50">Cancelados</p>
      <p class="mt-2 text-3xl font-bold text-[#2F3E34] dark:text-white">{{resumoInteresses.cancelados}}</p>
    </a>
  </div>

  {{#if success}}
  <div class="flex items-center gap-3 bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-200 dark:border-emerald-800 text-emerald-700 dark:text-emerald-300 px-4 py-3 rounded-xl text-sm font-medium">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
    </svg>
    Acao realizada com sucesso.
  </div>
  {{/if}}

  {{#if error}}
  <div class="flex items-center gap-3 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-300 px-4 py-3 rounded-xl text-sm font-medium">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M5.07 19h13.86c1.54 0 2.5-1.67 1.73-3L13.73 4c-.77-1.33-2.69-1.33-3.46 0L3.34 16c-.77 1.33.19 3 1.73 3z" />
    </svg>
    {{error}}
  </div>
  {{/if}}

  {{#if interesses.length}}
  <div class="space-y-3">
    {{#each interesses}}
    <div class="bg-white dark:bg-[#102235] border border-slate-200 dark:border-white/10 rounded-2xl p-5 shadow-sm">

      <div class="flex justify-between items-start gap-4 mb-3 flex-wrap">
        <div>
          <h2 class="text-base font-bold text-slate-800 dark:text-white">{{titulo_necessidade}}</h2>
          <p class="text-xs font-semibold text-slate-500 dark:text-white/55 mt-0.5">
            Solicitacao #{{id}}
          </p>
          <p class="text-xs text-slate-400 dark:text-white/40 mt-0.5">
            {{nome_usuario}} · {{email_usuario}}
          </p>
        </div>

        <span class="text-xs font-semibold px-2.5 py-1 rounded-full shrink-0
          {{#ifCond status 'pendente'}}bg-[#EAF3EC] text-[#3F5F45] dark:bg-[#6B8F71]/20 dark:text-[#DDEADB]{{/ifCond}}
          {{#ifCond status 'aceito'}}bg-[#EAF3EC] text-[#3F5F45] dark:bg-[#6B8F71]/20 dark:text-[#DDEADB]{{/ifCond}}
          {{#ifCond status 'recebido'}}bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-300{{/ifCond}}
          {{#ifCond status 'cancelado'}}bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-300{{/ifCond}}">
          {{status}}
        </span>
      </div>

      <div class="grid md:grid-cols-2 gap-2 text-xs text-slate-600 dark:text-white/70 mb-4">
        <div><span class="font-semibold text-slate-700 dark:text-white/80">Quantidade oferecida:</span> {{quantidade}}</div>
        <div><span class="font-semibold text-slate-700 dark:text-white/80">Data prevista:</span> {{data_prevista}}</div>
        <div><span class="font-semibold text-slate-700 dark:text-white/80">Meta:</span> {{meta}}</div>
        <div><span class="font-semibold text-slate-700 dark:text-white/80">Recebido ate agora:</span> {{quantidade_recebida}}</div>
        <div><span class="font-semibold text-slate-700 dark:text-white/80">Criado em:</span> {{criado_em}}</div>
      </div>

      {{#if observacao}}
      <p class="text-xs text-slate-500 dark:text-white/50 mb-4"><span class="font-semibold">Observacao:</span> {{observacao}}</p>
      {{/if}}

      {{#ifCond status 'pendente'}}
      <div class="flex gap-2 flex-wrap pt-3 border-t border-slate-100 dark:border-white/5">
        <form method="POST" action="/ong/interesses/{{id}}/aceitar">
          <button type="submit"
            class="px-4 py-2 rounded-xl bg-gradient-to-r from-[#6B8F71] to-[#2F3E34] text-white text-xs font-bold hover:opacity-90 transition shadow-sm">
            Aceitar interesse
          </button>
        </form>
        <button type="button" data-cancel-toggle="{{id}}"
          class="px-4 py-2 rounded-xl bg-red-500 text-white text-xs font-bold hover:opacity-90 transition shadow-sm">
          Cancelar
        </button>
      </div>
      <form method="POST" action="/ong/interesses/{{id}}/cancelar" data-cancel-form="{{id}}" class="hidden mt-3 pt-3 border-t border-slate-100 dark:border-white/5 space-y-3">
        <input type="hidden" name="status_retorno" value="pendente" />
        <div>
          <label for="motivo_cancelamento_{{id}}" class="block text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-white/50 mb-1">
            Motivo do cancelamento
          </label>
          <textarea id="motivo_cancelamento_{{id}}" name="motivo_cancelamento" rows="3" placeholder="Explique para o usuario o motivo do cancelamento."
            class="w-full rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 px-4 py-2.5 text-sm text-slate-900 dark:text-white placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-red-400 transition resize-none"></textarea>
        </div>
        <div class="flex gap-2 flex-wrap">
          <button type="submit"
            class="px-4 py-2 rounded-xl bg-red-500 text-white text-xs font-bold hover:opacity-90 transition shadow-sm">
            Confirmar cancelamento
          </button>
          <button type="button" data-cancel-close="{{id}}"
            class="px-4 py-2 rounded-xl border border-slate-200 dark:border-white/10 text-slate-600 dark:text-white/70 text-xs font-bold hover:opacity-80 transition">
            Fechar
          </button>
        </div>
      </form>
      {{/ifCond}}

      {{#ifCond status 'aceito'}}
      <div class="flex gap-2 flex-wrap pt-3 border-t border-slate-100 dark:border-white/5">
        <button type="button" data-receive-toggle="{{id}}"
          class="px-4 py-2 rounded-xl bg-emerald-500 text-white text-xs font-bold hover:opacity-90 transition shadow-sm">
          Confirmar recebimento
        </button>
        <button type="button" data-cancel-toggle="{{id}}"
          class="px-4 py-2 rounded-xl bg-red-500 text-white text-xs font-bold hover:opacity-90 transition shadow-sm">
          Cancelar
        </button>
      </div>
      <form method="POST" action="/ong/interesses/{{id}}/receber" data-receive-form="{{id}}" class="hidden mt-3 pt-3 border-t border-slate-100 dark:border-white/5 space-y-3">
        <div class="grid md:grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-white/50 mb-1">
              Quantidade oferecida
            </label>
            <input type="text" value="{{#if quantidade}}{{quantidade}}{{else}}Nao informada{{/if}}" readonly
              class="w-full rounded-xl border border-slate-200 dark:border-white/10 bg-slate-100 dark:bg-white/5 px-4 py-2.5 text-sm text-slate-600 dark:text-white/70 focus:outline-none" />
          </div>
          <div>
            <label for="quantidade_recebida_{{id}}" class="block text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-white/50 mb-1">
              Quantidade recebida pela ONG
            </label>
            <input type="number" id="quantidade_recebida_{{id}}" name="quantidade_recebida" min="1" {{#if quantidade}}max="{{quantidade}}"{{/if}} required placeholder="Informe a quantidade recebida"
              class="w-full rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 px-4 py-2.5 text-sm text-slate-900 dark:text-white placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-emerald-400 transition" />
          </div>
        </div>
        <div>
          <label for="observacao_recebimento_{{id}}" class="block text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-white/50 mb-1">
            Observacao sobre o item recebido
          </label>
          <textarea id="observacao_recebimento_{{id}}" name="observacao_recebimento" rows="3" placeholder="Ex: item veio em bom estado, completo, com pequenos sinais de uso..."
            class="w-full rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 px-4 py-2.5 text-sm text-slate-900 dark:text-white placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-emerald-400 transition resize-none"></textarea>
        </div>
        <div class="flex gap-2 flex-wrap">
          <button type="submit"
            class="px-4 py-2 rounded-xl bg-emerald-500 text-white text-xs font-bold hover:opacity-90 transition shadow-sm">
            Confirmar agora
          </button>
          <button type="button" data-receive-close="{{id}}"
            class="px-4 py-2 rounded-xl border border-slate-200 dark:border-white/10 text-slate-600 dark:text-white/70 text-xs font-bold hover:opacity-80 transition">
            Fechar
          </button>
        </div>
      </form>
      <form method="POST" action="/ong/interesses/{{id}}/cancelar" data-cancel-form="{{id}}" class="hidden mt-3 pt-3 border-t border-slate-100 dark:border-white/5 space-y-3">
        <input type="hidden" name="status_retorno" value="aceito" />
        <div>
          <label for="motivo_cancelamento_{{id}}" class="block text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-white/50 mb-1">
            Motivo do cancelamento
          </label>
          <textarea id="motivo_cancelamento_{{id}}" name="motivo_cancelamento" rows="3" placeholder="Explique para o usuario o motivo do cancelamento."
            class="w-full rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 px-4 py-2.5 text-sm text-slate-900 dark:text-white placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-red-400 transition resize-none"></textarea>
        </div>
        <div class="flex gap-2 flex-wrap">
          <button type="submit"
            class="px-4 py-2 rounded-xl bg-red-500 text-white text-xs font-bold hover:opacity-90 transition shadow-sm">
            Confirmar cancelamento
          </button>
          <button type="button" data-cancel-close="{{id}}"
            class="px-4 py-2 rounded-xl border border-slate-200 dark:border-white/10 text-slate-600 dark:text-white/70 text-xs font-bold hover:opacity-80 transition">
            Fechar
          </button>
        </div>
      </form>
      {{/ifCond}}

    </div>
    {{/each}}
  </div>

  {{> paginationControls}}

  {{else}}
  {{> emptyState message="Nenhum interesse encontrado para este filtro."}}
  {{/if}}

</div>

<script>
  document.querySelectorAll('[data-cancel-toggle]').forEach(function (button) {
    button.addEventListener('click', function () {
      const id = button.getAttribute('data-cancel-toggle');
      const form = document.querySelector('[data-cancel-form="' + id + '"]');
      if (form) {
        form.classList.remove('hidden');
      }
    });
  });

  document.querySelectorAll('[data-cancel-close]').forEach(function (button) {
    button.addEventListener('click', function () {
      const id = button.getAttribute('data-cancel-close');
      const form = document.querySelector('[data-cancel-form="' + id + '"]');
      if (form) {
        form.classList.add('hidden');
      }
    });
  });

  document.querySelectorAll('[data-receive-toggle]').forEach(function (button) {
    button.addEventListener('click', function () {
      const id = button.getAttribute('data-receive-toggle');
      const form = document.querySelector('[data-receive-form="' + id + '"]');
      if (form) {
        form.classList.remove('hidden');
      }
    });
  });

  document.querySelectorAll('[data-receive-close]').forEach(function (button) {
    button.addEventListener('click', function () {
      const id = button.getAttribute('data-receive-close');
      const form = document.querySelector('[data-receive-form="' + id + '"]');
      if (form) {
        form.classList.add('hidden');
      }
    });
  });
</script>
