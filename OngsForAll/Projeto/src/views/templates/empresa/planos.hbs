<div class="max-w-5xl mx-auto space-y-6">

  <div class="flex items-center justify-between flex-wrap gap-3">
    <div>
      <h2 class="text-2xl font-bold text-[#2D4BA6] dark:text-white">Planos da empresa</h2>
      <p class="text-sm text-slate-500 dark:text-white/60 mt-0.5">Escolha o limite de itens e beneficios da vitrine.</p>
    </div>
    <div class="px-4 py-2 rounded-2xl bg-white dark:bg-[#102235] border border-slate-200 dark:border-white/10 text-sm text-slate-600 dark:text-white/70">
      Itens no plano: <span class="font-bold text-[#2D4BA6] dark:text-white">{{totalItens}}</span>
      <span class="text-slate-400 dark:text-white/40">/ cadastrados: {{totalItensCadastrados}}</span>
    </div>
  </div>

  {{#if success}}
  <div class="flex items-center gap-3 px-4 py-3 rounded-xl bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-200 dark:border-emerald-800 text-emerald-700 dark:text-emerald-300 text-sm font-medium">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
    </svg>
    Plano atualizado com sucesso.
  </div>
  {{/if}}

  {{#if erro}}
  <div class="flex items-center gap-3 px-4 py-3 rounded-xl bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-300 text-sm font-medium">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    {{erro}}
  </div>
  {{/if}}

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    {{#each planos}}
    <form method="POST" action="/empresa/plano"
      class="bg-white dark:bg-[#102235] border {{#if isAtual}}border-violet-400 dark:border-violet-500 shadow-md{{else}}border-slate-200 dark:border-white/10 shadow-sm{{/if}} rounded-2xl p-6 flex flex-col min-h-[23rem]">
      <input type="hidden" name="plano" value="{{codigo}}" />

      <div class="flex items-start justify-between gap-3">
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-white/40">Plano</p>
          <h3 class="mt-2 text-2xl font-extrabold text-[#2D4BA6] dark:text-white">{{label}}</h3>
        </div>
        {{#if isAtual}}
        <span class="px-2.5 py-1 rounded-full bg-violet-100 dark:bg-violet-900/30 text-violet-700 dark:text-violet-300 text-xs font-bold">
          Atual
        </span>
        {{/if}}
      </div>

      <p class="mt-5 text-3xl font-extrabold text-slate-900 dark:text-white">{{preco}}</p>
      <p class="mt-2 text-sm text-slate-500 dark:text-white/50">Limite: <span class="font-semibold">{{limiteLabel}}</span></p>

      <div class="mt-5 pt-5 border-t border-slate-100 dark:border-white/10 flex-1">
        <p class="text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-white/40 mb-2">Beneficios</p>
        <p class="text-sm text-slate-600 dark:text-white/70 leading-relaxed">{{beneficio}}</p>
      </div>

      {{#if bloqueadoPorLimite}}
      <p class="mt-5 text-xs text-red-500 dark:text-red-300 font-semibold">
        Envie itens para rascunho para selecionar este plano.
      </p>
      {{/if}}

      <button type="submit"
        {{#unless canSelecionar}}disabled{{/unless}}
        {{#if isAtual}}disabled{{/if}}
        class="mt-5 w-full px-4 py-3 rounded-2xl text-sm font-bold transition
          {{#if isAtual}}bg-slate-100 dark:bg-white/10 text-slate-400 dark:text-white/40 cursor-not-allowed{{else}}{{#if canSelecionar}}bg-gradient-to-r from-violet-500 to-purple-700 text-white shadow hover:opacity-90{{else}}bg-slate-100 dark:bg-white/10 text-slate-400 dark:text-white/40 cursor-not-allowed{{/if}}{{/if}}">
        {{#if isAtual}}Plano atual{{else}}Selecionar plano{{/if}}
      </button>
    </form>
    {{/each}}
  </div>

</div>
