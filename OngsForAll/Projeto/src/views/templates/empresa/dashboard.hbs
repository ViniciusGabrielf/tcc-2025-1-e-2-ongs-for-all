<div class="max-w-4xl mx-auto space-y-8">

  <!-- Hero -->
  <div class="relative overflow-hidden rounded-2xl bg-gradient-to-r from-violet-500 to-purple-700 p-6 sm:p-10 shadow-lg">
    <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg%20width%3D%2260%22%20height%3D%2260%22%20viewBox%3D%220%200%2060%2060%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cg%20fill%3D%22none%22%20fill-rule%3D%22evenodd%22%3E%3Cg%20fill%3D%22%23ffffff%22%20fill-opacity%3D%220.05%22%3E%3Cpath%20d%3D%22M36%2034v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6%2034v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6%204V0H4v4H0v2h4v4h2V6h4V4H6z%22%2F%3E%3C%2Fg%3E%3C%2Fg%3E%3C%2Fsvg%3E')] opacity-50"></div>
    <div class="relative flex items-end justify-between gap-4 flex-wrap">
      <div>
        <h1 class="text-2xl sm:text-4xl font-extrabold text-white break-words">
          {{empresa.nome_fantasia}}
        </h1>
        <p class="mt-2 text-white/80 text-lg">Gerencie sua participação social</p>
      </div>
      <a href="/empresa/necessidades"
        class="shrink-0 inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-white/20 hover:bg-white/30 text-white text-sm font-semibold transition">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
        </svg>
        Explorar necessidades
      </a>
    </div>
  </div>

  {{#if cnpjStatus.mensagem}}
  <div class="rounded-2xl border p-5 shadow-sm
    {{#if cnpjStatus.bloqueiaAtividades}}bg-red-50 dark:bg-red-900/20 border-red-200 dark:border-red-800{{else}}bg-amber-50 dark:bg-amber-900/20 border-amber-200 dark:border-amber-800{{/if}}">
    <div class="flex items-start justify-between gap-4 flex-wrap">
      <div>
        <p class="text-sm font-bold {{#if cnpjStatus.bloqueiaAtividades}}text-red-700 dark:text-red-300{{else}}text-amber-700 dark:text-amber-300{{/if}}">
          Situacao do CNPJ
        </p>
        <p class="mt-1 text-sm {{#if cnpjStatus.bloqueiaAtividades}}text-red-600 dark:text-red-200{{else}}text-amber-700 dark:text-amber-200{{/if}}">
          {{cnpjStatus.mensagem}}
        </p>
        {{#if cnpjStatus.observacaoAdmin}}
        <p class="mt-2 text-xs font-semibold {{#if cnpjStatus.bloqueiaAtividades}}text-red-600 dark:text-red-200{{else}}text-amber-700 dark:text-amber-200{{/if}}">
          Observacao do admin: {{cnpjStatus.observacaoAdmin}}
        </p>
        {{/if}}
      </div>
      <a href="/empresa/perfil"
        class="px-4 py-2 rounded-xl bg-white dark:bg-white/10 text-sm font-bold {{#if cnpjStatus.bloqueiaAtividades}}text-red-700 dark:text-red-200{{else}}text-amber-700 dark:text-amber-200{{/if}} shadow-sm">
        Ir para o perfil
      </a>
    </div>
  </div>
  {{/if}}

  <!-- Cards de resumo -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
    <a href="/empresa/apoios?status=aberta" class="group bg-white dark:bg-white/5 p-4 rounded-2xl border border-slate-200 dark:border-white/10 shadow-sm hover:shadow-md transition-all duration-200 border-l-4 border-l-amber-400">
      <p class="text-xs font-semibold text-slate-500 dark:text-white/50 mb-1">Pendentes</p>
      <p class="text-3xl font-extrabold text-slate-800 dark:text-white">{{resumo.pendentes}}</p>
    </a>
    <a href="/empresa/apoios?status=em_andamento" class="group bg-white dark:bg-white/5 p-4 rounded-2xl border border-slate-200 dark:border-white/10 shadow-sm hover:shadow-md transition-all duration-200 border-l-4 border-l-blue-500">
      <p class="text-xs font-semibold text-slate-500 dark:text-white/50 mb-1">Em andamento</p>
      <p class="text-3xl font-extrabold text-slate-800 dark:text-white">{{resumo.em_andamento}}</p>
    </a>
    <a href="/empresa/apoios?status=concluida" class="group bg-white dark:bg-white/5 p-4 rounded-2xl border border-slate-200 dark:border-white/10 shadow-sm hover:shadow-md transition-all duration-200 border-l-4 border-l-emerald-500">
      <p class="text-xs font-semibold text-slate-500 dark:text-white/50 mb-1">Concluídos</p>
      <p class="text-3xl font-extrabold text-slate-800 dark:text-white">{{resumo.concluidas}}</p>
    </a>
    <a href="/empresa/apoios?status=cancelada" class="group bg-white dark:bg-white/5 p-4 rounded-2xl border border-slate-200 dark:border-white/10 shadow-sm hover:shadow-md transition-all duration-200 border-l-4 border-l-red-400">
      <p class="text-xs font-semibold text-slate-500 dark:text-white/50 mb-1">Cancelados</p>
      <p class="text-3xl font-extrabold text-slate-800 dark:text-white">{{resumo.canceladas}}</p>
    </a>
  </div>

  <!-- Abas de filtro + busca -->
  <div class="flex items-center gap-1 flex-wrap">
    <a href="/empresa/dashboard{{#if buscaAtual}}?busca={{buscaAtual}}{{/if}}"
      class="shrink-0 px-4 py-2 rounded-full text-sm font-semibold transition-all duration-200
        {{#if isTabTodos}}bg-violet-600 text-white shadow-sm{{else}}bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 text-slate-600 dark:text-white/60 hover:shadow-sm{{/if}}">
      Todos
    </a>
    <a href="/empresa/dashboard?status=aberta{{#if buscaAtual}}&busca={{buscaAtual}}{{/if}}"
      class="shrink-0 px-4 py-2 rounded-full text-sm font-semibold transition-all duration-200
        {{#if isTabPendentes}}bg-amber-500 text-white shadow-sm{{else}}bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 text-slate-600 dark:text-white/60 hover:shadow-sm{{/if}}">
      Pendentes
    </a>
    <a href="/empresa/dashboard?status=em_andamento{{#if buscaAtual}}&busca={{buscaAtual}}{{/if}}"
      class="shrink-0 px-4 py-2 rounded-full text-sm font-semibold transition-all duration-200
        {{#if isTabAndamento}}bg-blue-600 text-white shadow-sm{{else}}bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 text-slate-600 dark:text-white/60 hover:shadow-sm{{/if}}">
      Em andamento
    </a>
    <a href="/empresa/dashboard?status=concluida{{#if buscaAtual}}&busca={{buscaAtual}}{{/if}}"
      class="shrink-0 px-4 py-2 rounded-full text-sm font-semibold transition-all duration-200
        {{#if isTabConcluidas}}bg-emerald-600 text-white shadow-sm{{else}}bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 text-slate-600 dark:text-white/60 hover:shadow-sm{{/if}}">
      Concluídos
    </a>
    <a href="/empresa/dashboard?status=cancelada{{#if buscaAtual}}&busca={{buscaAtual}}{{/if}}"
      class="shrink-0 px-4 py-2 rounded-full text-sm font-semibold transition-all duration-200
        {{#if isTabCancelados}}bg-red-500 text-white shadow-sm{{else}}bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 text-slate-600 dark:text-white/60 hover:shadow-sm{{/if}}">
      Cancelados
    </a>

    <form method="GET" action="/empresa/dashboard" class="ml-auto flex items-center gap-1.5 shrink-0">
      {{#if statusFiltro}}<input type="hidden" name="status" value="{{statusFiltro}}" />{{/if}}
      <input
        type="text"
        name="busca"
        value="{{buscaAtual}}"
        placeholder="Título ou ONG..."
        class="px-3 py-2 rounded-full border border-slate-200 dark:border-white/10 bg-white dark:bg-white/5 text-slate-900 dark:text-white text-xs placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-violet-500 w-40 transition"
      />
      <button type="submit"
        class="shrink-0 p-2 rounded-full border border-slate-200 dark:border-white/10 bg-white dark:bg-white/5 text-slate-500 dark:text-white/50 hover:text-violet-600 hover:border-violet-400/40 transition">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </button>
      {{#if buscaAtual}}
      <a href="/empresa/dashboard{{#if statusFiltro}}?status={{statusFiltro}}{{/if}}"
        class="shrink-0 p-2 rounded-full border border-slate-200 dark:border-white/10 text-slate-400 hover:text-red-500 hover:border-red-300 transition"
        title="Limpar busca">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </a>
      {{/if}}
    </form>
  </div>

  <!-- Lista de apoios -->
  {{#if apoios.length}}
  <div class="space-y-3">
    {{#each apoios}}
    <div class="bg-white dark:bg-white/[0.04] border border-slate-200 dark:border-white/8 rounded-2xl overflow-hidden shadow-sm hover:shadow-md hover:-translate-y-px transition-all duration-200
      {{#if isAberta}}border-l-[3px] border-l-amber-400{{/if}}
      {{#if isEmAndamento}}border-l-[3px] border-l-blue-500{{/if}}
      {{#if isConcluida}}border-l-[3px] border-l-emerald-500{{/if}}
      {{#if isCancelada}}border-l-[3px] border-l-red-400{{/if}}
    ">
      <div class="flex items-start gap-4 p-4 sm:p-5">

        <div class="shrink-0 mt-0.5">
          {{#if tipoIsBem}}
          <div class="w-10 h-10 rounded-xl bg-blue-100 dark:bg-blue-500/15 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-600 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
            </svg>
          </div>
          {{/if}}
          {{#if tipoIsServico}}
          <div class="w-10 h-10 rounded-xl bg-violet-100 dark:bg-violet-500/15 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-violet-600 dark:text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          {{/if}}
          {{#if tipoIsVoluntariado}}
          <div class="w-10 h-10 rounded-xl bg-emerald-100 dark:bg-emerald-500/15 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-emerald-600 dark:text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          {{/if}}
        </div>

        <div class="flex-1 min-w-0">
          <div class="flex items-start justify-between gap-3 flex-wrap">
            <div class="min-w-0">
              <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 dark:text-white/40 mb-0.5">{{tipoLabel}}</p>
              <p class="font-bold text-slate-800 dark:text-white text-sm sm:text-[15px] leading-snug">{{titulo_necessidade}}</p>
              <p class="text-xs text-slate-500 dark:text-white/50 mt-0.5">{{nome_ong}}</p>
            </div>
            <span class="shrink-0 px-2.5 py-1 rounded-full text-xs font-bold
              {{#if isAberta}}bg-amber-100 text-amber-700 dark:bg-amber-500/20 dark:text-amber-300{{/if}}
              {{#if isEmAndamento}}bg-blue-100 text-blue-700 dark:bg-blue-500/20 dark:text-blue-300{{/if}}
              {{#if isConcluida}}bg-emerald-100 text-emerald-700 dark:bg-emerald-500/20 dark:text-emerald-300{{/if}}
              {{#if isCancelada}}bg-red-100 text-red-700 dark:bg-red-500/20 dark:text-red-300{{/if}}
            ">{{statusLabel}}</span>
          </div>

          <div class="mt-3 flex flex-wrap gap-x-4 gap-y-1.5 text-xs text-slate-500 dark:text-white/40">
            <span class="flex items-center gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              Registrado em {{criado_em}}
            </span>
          </div>
        </div>
      </div>
    </div>
    {{/each}}
  </div>

  {{> paginationControls}}

  {{else}}

  <div class="flex flex-col items-center justify-center py-20 text-center bg-white dark:bg-white/[0.03] border border-slate-200 dark:border-white/8 rounded-2xl">
    <div class="w-14 h-14 rounded-2xl bg-slate-100 dark:bg-white/8 flex items-center justify-center mb-4">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-slate-300 dark:text-white/25" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
      </svg>
    </div>
    <p class="text-sm font-bold text-slate-500 dark:text-white/50 mb-1">Nenhum apoio encontrado</p>
    <p class="text-xs text-slate-400 dark:text-white/30 max-w-[240px] leading-relaxed mb-5">
      {{#if isTabTodos}}Apoie uma necessidade para começar a contribuir.{{else}}Nenhum apoio nesta categoria.{{/if}}
    </p>
    {{#unless isTabTodos}}
    <a href="/empresa/dashboard"
      class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full border border-slate-200 dark:border-white/10 text-xs font-semibold text-slate-500 dark:text-white/60 hover:opacity-80 transition">
      Ver todos
    </a>
    {{/unless}}
    {{#if isTabTodos}}
    {{#unless cnpjStatus.bloqueiaAtividades}}
    <a href="/empresa/necessidades"
      class="inline-block bg-gradient-to-r from-violet-500 to-purple-700 text-white font-bold px-6 py-3 rounded-xl shadow hover:opacity-90 transition text-sm">
      Explorar necessidades
    </a>
    {{/unless}}
    {{#if cnpjStatus.bloqueiaAtividades}}
    <a href="/empresa/perfil"
      class="inline-block bg-gradient-to-r from-violet-500 to-purple-700 text-white font-bold px-6 py-3 rounded-xl shadow hover:opacity-90 transition text-sm">
      Regularizar CNPJ
    </a>
    {{/if}}
    {{/if}}
  </div>

  {{/if}}

</div>
