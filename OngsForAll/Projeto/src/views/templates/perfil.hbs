<div class="max-w-2xl mx-auto space-y-6" style="--theme-primary: {{#if isOngDashboard}}#6B8F71{{else}}#4886D9{{/if}}; --theme-strong: {{#if isOngDashboard}}#2F3E34{{else}}#2D4BA6{{/if}}; --theme-accent: {{#if isOngDashboard}}#3F5F45{{else}}#EC4899{{/if}}; --theme-soft: {{#if isOngDashboard}}#EAF3EC{{else}}#DBEAFE{{/if}}; --theme-soft-2: {{#if isOngDashboard}}#DDEADB{{else}}#F3E8FF{{/if}};">

  <div>
    <h2 class="text-2xl font-bold text-[var(--theme-strong)] dark:text-white">
      {{#if isOng}}Perfil da ONG{{else}}Meu perfil{{/if}}
    </h2>
    <p class="text-sm text-slate-500 dark:text-white/60 mt-0.5">Atualize suas informações pessoais</p>
  </div>

  {{#if success}}
  <div data-dismissible-alert class="relative px-4 py-3 pr-12 rounded-xl bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-200 dark:border-emerald-800 text-emerald-700 dark:text-emerald-300 text-sm font-medium">
    Perfil atualizado com sucesso!
    <button type="button" data-dismiss-alert class="absolute top-3 right-3 inline-flex items-center justify-center w-7 h-7 rounded-lg text-current/80 hover:bg-black/5 dark:hover:bg-white/10 transition" aria-label="Fechar aviso">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>
  <script>
    (function () {
      var url = new URL(window.location.href);
      url.searchParams.delete("success");
      window.history.replaceState({}, document.title, url.toString());
    })();
  </script>
  {{/if}}

  {{#if message}}
  <div data-dismissible-alert class="relative px-4 py-3 pr-12 rounded-xl bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-300 text-sm">
    {{message}}
    <button type="button" data-dismiss-alert class="absolute top-3 right-3 inline-flex items-center justify-center w-7 h-7 rounded-lg text-current/80 hover:bg-black/5 dark:hover:bg-white/10 transition" aria-label="Fechar aviso">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>
  {{/if}}

  {{#if documentoPendingNotice}}
  <div data-dismissible-alert class="relative px-4 py-3 pr-12 rounded-xl bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 text-amber-700 dark:text-amber-300 text-sm font-medium">
    A alteração do {{#if isOng}}CNPJ{{else}}CPF{{/if}} foi enviada para aprovação do admin.
    <button type="button" data-dismiss-alert class="absolute top-3 right-3 inline-flex items-center justify-center w-7 h-7 rounded-lg text-current/80 hover:bg-black/5 dark:hover:bg-white/10 transition" aria-label="Fechar aviso">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>
  {{/if}}

  {{#if user.documentoStatus.mensagem}}
  <div data-dismissible-alert class="relative px-4 py-3 pr-12 rounded-xl border text-sm font-medium
    {{#if user.documentoStatus.solicitacaoRejeitada}}bg-red-50 dark:bg-red-900/20 border-red-200 dark:border-red-800 text-red-700 dark:text-red-300{{else}}bg-amber-50 dark:bg-amber-900/20 border-amber-200 dark:border-amber-800 text-amber-700 dark:text-amber-300{{/if}}">
    {{user.documentoStatus.mensagem}}
    {{#if user.documentoStatus.observacaoAdmin}}
    <p class="mt-2 text-xs font-semibold">Observação do admin: {{user.documentoStatus.observacaoAdmin}}</p>
    {{/if}}
    <button type="button" data-dismiss-alert class="absolute top-3 right-3 inline-flex items-center justify-center w-7 h-7 rounded-lg text-current/80 hover:bg-black/5 dark:hover:bg-white/10 transition" aria-label="Fechar aviso">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>
  {{/if}}

  <form action="/perfil/editar" method="POST" {{#if isOng}}enctype="multipart/form-data"{{/if}}
    class="bg-white dark:bg-[#102235] border border-slate-200 dark:border-white/10 rounded-2xl p-6 shadow-sm space-y-5">

    <div class="flex items-center gap-5">
      {{#if isOng}}
        {{#if user.logo}}
        <img src="{{user.logo}}" class="w-20 h-20 rounded-2xl object-cover border border-slate-200 dark:border-white/10 shadow-sm shrink-0" />
        {{else}}
        <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-[var(--theme-primary)] to-[var(--theme-strong)] flex items-center justify-center text-white font-bold text-2xl shadow-sm shrink-0">
          {{#if user.nome}}{{user.nome.[0]}}{{else}}?{{/if}}
        </div>
        {{/if}}
        <div class="flex-1">
          <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">Logo da ONG</label>
          <input type="file" name="logo" accept="image/jpeg,image/png,image/webp,image/gif"
            class="w-full text-sm text-slate-500 dark:text-white/50 file:mr-3 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-[var(--theme-strong)]/10 dark:file:bg-[var(--theme-primary)]/20 file:text-[var(--theme-strong)] dark:file:text-[var(--theme-primary)] hover:file:opacity-80" />
          <p class="text-xs text-slate-400 dark:text-white/30 mt-1">JPG, PNG, WebP ou GIF - max. 2MB</p>
        </div>
      {{else}}
        <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-[var(--theme-primary)] to-[var(--theme-strong)] flex items-center justify-center text-white font-bold text-2xl shadow-sm shrink-0">
          {{#if user.nome}}{{user.nome.[0]}}{{else}}?{{/if}}
        </div>
        <div>
          <p class="text-sm font-semibold text-slate-700 dark:text-white/80">{{user.nome}}</p>
          <p class="text-xs text-slate-400 dark:text-white/40 mt-0.5">Conta pessoal</p>
        </div>
      {{/if}}
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">Nome *</label>
        <input type="text" name="nome" value="{{user.nome}}" required maxlength="255"
          class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-[var(--theme-primary)]" />
      </div>
      <div>
        <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">E-mail *</label>
        <input type="email" name="email" value="{{user.email}}" required maxlength="255"
          class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-[var(--theme-primary)]" />
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">Telefone</label>
        <input type="tel" name="telefone" id="telefone_perfil" value="{{user.telefone}}" maxlength="20" placeholder="(00) 00000-0000"
          class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-[var(--theme-primary)]" />
      </div>

      {{#if isOng}}
      <div>
        <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">Área de atuação</label>
        <input type="text" name="area_atuacao" value="{{user.area_atuacao}}" maxlength="100" placeholder="Ex: Educação, Saúde..."
          class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-[var(--theme-primary)]" />
      </div>
      {{else}}
      {{#if user.cpf}}
      <div>
        <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">CPF</label>
        <input type="text" name="cpf" id="cpf_perfil" value="{{user.cpf}}" maxlength="14"
          class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-[var(--theme-primary)]" />
        <p class="text-xs text-slate-400 dark:text-white/30 mt-1">Alterações de CPF ficam pendentes para aprovação do admin.</p>
        {{#if user.documentoStatus.documentoPendente}}
        <p class="text-xs text-amber-600 dark:text-amber-300 mt-1">Solicitação pendente: {{user.documentoStatus.documentoPendente}}</p>
        {{/if}}
      </div>
      {{/if}}
      {{/if}}
    </div>

    {{#if isOng}}
    {{#if user.cnpj}}
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">CNPJ</label>
        <input type="text" name="cnpj" id="cnpj_ong_perfil" value="{{user.cnpj}}" maxlength="18"
          class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-[var(--theme-primary)]" />
        <p class="text-xs text-slate-400 dark:text-white/30 mt-1">Alterações de CNPJ ficam pendentes para aprovação do admin.</p>
        {{#if user.documentoStatus.documentoPendente}}
        <p class="text-xs text-amber-600 dark:text-amber-300 mt-1">Solicitação pendente: {{user.documentoStatus.documentoPendente}}</p>
        {{/if}}
      </div>
    </div>
    {{/if}}
    {{/if}}

    {{#if isOng}}
    {{#if user.cnpj}}
    <div class="rounded-2xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 p-4 space-y-1">
      <p class="text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-white/40">CNPJ atual em uso</p>
      <p class="text-sm font-bold text-slate-800 dark:text-white">{{user.cnpj}}</p>
      <p class="text-xs text-slate-500 dark:text-white/50">Este é o CNPJ atualmente aprovado para a ONG.</p>
    </div>
    {{/if}}
    {{else}}
    {{#if user.cpf}}
    <div class="rounded-2xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 p-4 space-y-1">
      <p class="text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-white/40">CPF atual em uso</p>
      <p class="text-sm font-bold text-slate-800 dark:text-white">{{user.cpf}}</p>
      <p class="text-xs text-slate-500 dark:text-white/50">Este é o CPF atualmente aprovado para a conta.</p>
    </div>
    {{/if}}
    {{/if}}

    {{#if isOng}}
    <hr class="border-slate-200 dark:border-white/10" />

    <div>
      <h3 class="text-base font-bold text-[var(--theme-strong)] dark:text-white mb-0.5">Localização</h3>
      <p class="text-xs text-slate-400 dark:text-white/40 mb-4">Opcional. Permite que usuários e empresas vejam sua ONG no mapa.</p>

      {{! Atendimento remoto }}
      <label class="flex items-center gap-3 cursor-pointer mb-4">
        <input type="checkbox" name="atendimento_remoto" id="chk_remoto" value="1" {{#if user.atendimento_remoto}}checked{{/if}}
          class="w-4 h-4 rounded accent-[var(--theme-primary)] cursor-pointer" />
        <span class="text-sm text-slate-700 dark:text-white/80">Esta ONG atende remotamente (sem local físico público)</span>
      </label>

      {{! CEP + busca automática }}
      <div id="bloco_endereco" class="space-y-4">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 items-end">
          <div class="sm:col-span-2">
            <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">CEP</label>
            <input type="text" name="cep" id="input_cep" value="{{user.cep}}" maxlength="9" placeholder="00000-000"
              class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-[var(--theme-primary)]" />
          </div>
          <button type="button" id="btn_buscar_cep"
            class="px-4 py-2.5 rounded-xl bg-[var(--theme-strong)]/10 dark:bg-[var(--theme-primary)]/20 text-[var(--theme-strong)] dark:text-[var(--theme-primary)] text-sm font-semibold hover:opacity-80 transition">
            Buscar CEP
          </button>
        </div>
        <p id="cep_status" class="hidden text-xs"></p>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          <div class="sm:col-span-2">
            <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">Logradouro</label>
            <input type="text" name="logradouro" id="input_logradouro" value="{{user.logradouro}}" maxlength="255"
              class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-[var(--theme-primary)]" />
          </div>
          <div>
            <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">Número</label>
            <input type="text" name="numero" id="input_numero" value="{{user.numero}}" maxlength="30"
              class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-[var(--theme-primary)]" />
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">Complemento</label>
            <input type="text" name="complemento" id="input_complemento" value="{{user.complemento}}" maxlength="100"
              class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-[var(--theme-primary)]" />
          </div>
          <div>
            <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">Bairro</label>
            <input type="text" name="bairro" id="input_bairro" value="{{user.bairro}}" maxlength="100"
              class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-[var(--theme-primary)]" />
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          <div class="sm:col-span-2">
            <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">Cidade</label>
            <input type="text" name="cidade" id="input_cidade" value="{{user.cidade}}" maxlength="100"
              class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-[var(--theme-primary)]" />
          </div>
          <div>
            <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">Estado (UF)</label>
            <input type="text" name="estado" id="input_estado" value="{{user.estado}}" maxlength="2" placeholder="SP"
              class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-[var(--theme-primary)]" />
          </div>
        </div>

        <div class="space-y-3">
          <label class="flex items-center gap-3 cursor-pointer">
            <input type="checkbox" name="localizacao_publica" id="chk_publica" value="1" {{#if user.localizacao_publica}}checked{{/if}}
              class="w-4 h-4 rounded accent-[var(--theme-primary)] cursor-pointer" />
            <span class="text-sm text-slate-700 dark:text-white/80">Tornar localização pública</span>
          </label>
          <label class="flex items-center gap-3 cursor-pointer">
            <input type="checkbox" name="localizacao_aproximada" id="chk_aproximada" value="1" {{#if user.localizacao_aproximada}}checked{{/if}}
              class="w-4 h-4 rounded accent-[var(--theme-primary)] cursor-pointer" />
            <span class="text-sm text-slate-700 dark:text-white/80">Exibir localização aproximada (sem ponto exato)</span>
          </label>
        </div>
      </div>

      <div>
        <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">Instruções de chegada</label>
        <textarea name="instrucoes_chegada" rows="3" maxlength="500" placeholder="Ex: Atendimento somente com agendamento. Entrada pela rua lateral."
          class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-[var(--theme-primary)] resize-none">{{user.instrucoes_chegada}}</textarea>
        <p class="text-xs text-slate-400 dark:text-white/30 mt-1">Exibido publicamente. Inclua informações de acesso, horários ou como entrar em contato.</p>
      </div>
    </div>
    {{/if}}

    <div>
      <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">
        Nova senha
        <span class="text-slate-400 dark:text-white/30 font-normal text-xs ml-1">(deixe em branco para manter)</span>
      </label>
      <input type="password" name="password" placeholder="********" minlength="6"
        class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-[var(--theme-primary)]" />
    </div>

    <div class="flex gap-3 pt-2">
      <button type="submit"
        class="flex-1 py-3 rounded-2xl bg-gradient-to-r from-[var(--theme-primary)] to-[var(--theme-strong)] text-white font-bold text-sm shadow hover:opacity-90 transition">
        Salvar alterações
      </button>
      <a href="{{backUrl}}"
        class="px-5 py-3 rounded-2xl border border-slate-200 dark:border-white/15 text-slate-600 dark:text-white/70 text-sm font-semibold hover:opacity-80 transition">
        Cancelar
      </a>
    </div>
  </form>

</div>

<script>
  document.querySelectorAll('[data-dismiss-alert]').forEach(function (button) {
    button.addEventListener('click', function () {
      const alert = button.closest('[data-dismissible-alert]');
      if (alert) {
        alert.style.display = 'none';
      }
    });
  });

  // Localização: toggle bloco endereço ao marcar "remoto"
  (function () {
    var chkRemoto  = document.getElementById('chk_remoto');
    var blocoEnd   = document.getElementById('bloco_endereco');
    if (!chkRemoto || !blocoEnd) return;

    function toggleBlocoEndereco() {
      blocoEnd.style.display = chkRemoto.checked ? 'none' : '';
    }
    chkRemoto.addEventListener('change', toggleBlocoEndereco);
    toggleBlocoEndereco();
  })();

  // Busca automática de CEP via ViaCEP
  (function () {
    var btnBuscar = document.getElementById('btn_buscar_cep');
    var inputCep  = document.getElementById('input_cep');
    var status    = document.getElementById('cep_status');
    if (!btnBuscar || !inputCep) return;

    function setStatus(msg, ok) {
      if (!status) return;
      status.textContent = msg;
      status.className = 'text-xs ' + (ok ? 'text-emerald-600 dark:text-emerald-400' : 'text-red-500 dark:text-red-400');
      status.classList.remove('hidden');
    }

    function preencherCampo(id, valor) {
      var el = document.getElementById(id);
      if (el && valor) el.value = valor;
    }

    function maskCep(val) {
      return val.replace(/\D/g, '').slice(0, 8).replace(/^(\d{5})(\d)/, '$1-$2');
    }

    inputCep.addEventListener('input', function () {
      inputCep.value = maskCep(inputCep.value);
    });

    btnBuscar.addEventListener('click', async function () {
      var cep = inputCep.value.replace(/\D/g, '');
      if (cep.length !== 8) { setStatus('Informe um CEP válido com 8 dígitos.', false); return; }
      btnBuscar.disabled = true;
      btnBuscar.textContent = 'Buscando...';
      try {
        var resp = await fetch('/api/cep/' + cep);
        if (!resp.ok) { setStatus('Não foi possível encontrar esse CEP.', false); return; }
        var dados = await resp.json();
        preencherCampo('input_logradouro', dados.logradouro);
        preencherCampo('input_bairro', dados.bairro);
        preencherCampo('input_cidade', dados.cidade);
        preencherCampo('input_estado', dados.estado);
        setStatus('Endereço preenchido automaticamente.', true);
      } catch {
        setStatus('Erro ao buscar o CEP. Tente novamente.', false);
      } finally {
        btnBuscar.disabled = false;
        btnBuscar.textContent = 'Buscar CEP';
      }
    });
  })();

  const cpfPerfilInput = document.getElementById('cpf_perfil');
  if (cpfPerfilInput) {
    cpfPerfilInput.addEventListener('input', function (e) {
      let value = e.target.value.replace(/\D/g, '').slice(0, 11);
      value = value.replace(/(\d{3})(\d)/, '$1.$2');
      value = value.replace(/(\d{3})(\d)/, '$1.$2');
      value = value.replace(/(\d{3})(\d{1,2})$/, '$1-$2');
      e.target.value = value;
    });
  }

  const cnpjOngPerfilInput = document.getElementById('cnpj_ong_perfil');
  if (cnpjOngPerfilInput) {
    cnpjOngPerfilInput.addEventListener('input', function (e) {
      let value = e.target.value.replace(/\D/g, '').slice(0, 14);
      value = value.replace(/^(\d{2})(\d)/, '$1.$2');
      value = value.replace(/^(\d{2})\.(\d{3})(\d)/, '$1.$2.$3');
      value = value.replace(/\.(\d{3})(\d)/, '.$1/$2');
      value = value.replace(/(\d{4})(\d)/, '$1-$2');
      e.target.value = value;
    });
  }
</script>
