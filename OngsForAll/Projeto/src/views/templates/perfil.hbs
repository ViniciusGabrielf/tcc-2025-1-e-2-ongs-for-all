<div class="max-w-2xl mx-auto space-y-6" style="--theme-primary: {{#if isOngDashboard}}#6B8F71{{else}}#4886D9{{/if}}; --theme-strong: {{#if isOngDashboard}}#2F3E34{{else}}#2D4BA6{{/if}}; --theme-accent: {{#if isOngDashboard}}#3F5F45{{else}}#EC4899{{/if}}; --theme-soft: {{#if isOngDashboard}}#EAF3EC{{else}}#DBEAFE{{/if}}; --theme-soft-2: {{#if isOngDashboard}}#DDEADB{{else}}#F3E8FF{{/if}};">

  <div>
    <h2 class="text-2xl font-bold text-[var(--theme-strong)] dark:text-white">
      {{#if isOng}}Perfil da ONG{{else}}Meu perfil{{/if}}
    </h2>
    <p class="text-sm text-slate-500 dark:text-white/60 mt-0.5">Atualize suas informações pessoais</p>
  </div>

  {{#if success}}
  <div class="px-4 py-3 rounded-xl bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-200 dark:border-emerald-800 text-emerald-700 dark:text-emerald-300 text-sm font-medium">
    Perfil atualizado com sucesso!
  </div>
  <script>
    (function () {
      var url = new URL(window.location.href);
      url.searchParams.delete("success");
      window.history.replaceState({}, document.title, url.toString());
    })();
  </script>
  {{/if}}

  {{#if message}}
  <div class="px-4 py-3 rounded-xl bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-300 text-sm">
    {{message}}
  </div>
  {{/if}}

  <form action="/perfil/editar" method="POST" {{#if isOng}}enctype="multipart/form-data"{{/if}}
    class="bg-white dark:bg-[#102235] border border-slate-200 dark:border-white/10 rounded-2xl p-6 shadow-sm space-y-5">

    <!-- Avatar / Logo -->
    <div class="flex items-center gap-5">
      {{#if isOng}}
        {{#if user.logo}}
        <img src="{{user.logo}}" class="w-20 h-20 rounded-2xl object-cover border border-slate-200 dark:border-white/10 shadow-sm shrink-0" />
        {{else}}
        <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-[var(--theme-primary)] to-[var(--theme-strong)] flex items-center justify-center text-white font-bold text-2xl shadow-sm shrink-0">
          {{#if user.nome}}{{user.nome.[0]}}{{else}}?{{/if}}
        </div>
        {{/if}}
        <div class="flex-1">
          <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">Logo da ONG</label>
          <input type="file" name="logo" accept="image/jpeg,image/png,image/webp,image/gif"
            class="w-full text-sm text-slate-500 dark:text-white/50 file:mr-3 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-[var(--theme-strong)]/10 dark:file:bg-[var(--theme-primary)]/20 file:text-[var(--theme-strong)] dark:file:text-[var(--theme-primary)] hover:file:opacity-80" />
          <p class="text-xs text-slate-400 dark:text-white/30 mt-1">JPG, PNG, WebP ou GIF · máx. 2MB</p>
        </div>
      {{else}}
        <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-[var(--theme-primary)] to-[var(--theme-strong)] flex items-center justify-center text-white font-bold text-2xl shadow-sm shrink-0">
          {{#if user.nome}}{{user.nome.[0]}}{{else}}?{{/if}}
        </div>
        <div>
          <p class="text-sm font-semibold text-slate-700 dark:text-white/80">{{user.nome}}</p>
          <p class="text-xs text-slate-400 dark:text-white/40 mt-0.5">Conta pessoal</p>
        </div>
      {{/if}}
    </div>

    <!-- Nome -->
    <div>
      <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">Nome *</label>
      <input type="text" name="nome" value="{{user.nome}}" required maxlength="255"
        class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-[var(--theme-primary)]" />
    </div>

    <!-- Email -->
    <div>
      <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">E-mail *</label>
      <input type="email" name="email" value="{{user.email}}" required maxlength="255"
        class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-[var(--theme-primary)]" />
    </div>

    <!-- Telefone -->
    <div>
      <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">Telefone</label>
      <input type="tel" name="telefone" value="{{user.telefone}}" maxlength="20" placeholder="(00) 00000-0000"
        class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-[var(--theme-primary)]" />
    </div>

    {{#if isOng}}
    <!-- Área de atuação (somente ONG) -->
    <div>
      <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">Área de atuação</label>
      <input type="text" name="area_atuacao" value="{{user.area_atuacao}}" maxlength="100" placeholder="Ex: Educação, Saúde, Meio Ambiente..."
        class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-[var(--theme-primary)]" />
    </div>
    {{/if}}

    <!-- CPF somente leitura (usuário) -->
    {{#unless isOng}}
    {{#if user.cpf}}
    <div>
      <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">CPF</label>
      <input type="text" value="{{user.cpf}}" disabled
        class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-100 dark:bg-white/5 text-slate-400 dark:text-white/40 text-sm cursor-not-allowed" />
    </div>
    {{/if}}
    {{/unless}}

    <!-- CNPJ somente leitura (ONG) -->
    {{#if isOng}}
    {{#if user.cnpj}}
    <div>
      <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">CNPJ</label>
      <input type="text" value="{{user.cnpj}}" disabled
        class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-100 dark:bg-white/5 text-slate-400 dark:text-white/40 text-sm cursor-not-allowed" />
    </div>
    {{/if}}
    {{/if}}

    <!-- Separador senha -->
    <div class="pt-1 border-t border-slate-100 dark:border-white/5">
      <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">
        Nova senha
        <span class="text-slate-400 dark:text-white/30 font-normal text-xs ml-1">(deixe em branco para manter)</span>
      </label>
      <input type="password" name="password" placeholder="••••••••" minlength="6"
        class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-[var(--theme-primary)]" />
    </div>

    <!-- Botões -->
    <div class="flex gap-3 pt-2">
      <button type="submit"
        class="flex-1 py-3 rounded-2xl bg-gradient-to-r from-[var(--theme-primary)] to-[var(--theme-strong)] text-white font-bold text-sm shadow hover:opacity-90 transition">
        Salvar alterações
      </button>
      <a href="{{backUrl}}"
        class="px-5 py-3 rounded-2xl border border-slate-200 dark:border-white/15 text-slate-600 dark:text-white/70 text-sm font-semibold hover:opacity-80 transition">
        Cancelar
      </a>
    </div>
  </form>

</div>
