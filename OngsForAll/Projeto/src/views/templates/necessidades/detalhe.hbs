<section class="min-h-screen px-4 sm:px-6 py-6 sm:py-10 {{#unless user}}pt-28 sm:pt-32{{/unless}}" style="--theme-primary: {{#if isOngDashboard}}#6B8F71{{else}}#4886D9{{/if}}; --theme-strong: {{#if isOngDashboard}}#2F3E34{{else}}#2D4BA6{{/if}}; --theme-accent: {{#if isOngDashboard}}#3F5F45{{else}}#EC4899{{/if}}; --theme-soft: {{#if isOngDashboard}}#EAF3EC{{else}}#DBEAFE{{/if}}; --theme-soft-2: {{#if isOngDashboard}}#DDEADB{{else}}#F3E8FF{{/if}};">
  <div class="max-w-3xl mx-auto">

    <!-- Badges de status -->
    <div class="flex gap-2 flex-wrap mb-3">
      {{#if necessidade.isVoluntariado}}
      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400 text-xs font-semibold">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
        Voluntariado
      </span>
      {{else if necessidade.isServico}}
      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-[var(--theme-soft-2)] dark:bg-[var(--theme-primary)]/20 text-[var(--theme-accent)] dark:text-[var(--theme-soft)] text-xs font-semibold">
        Serviço
      </span>
      {{else}}
      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-[var(--theme-soft)] dark:bg-[var(--theme-primary)]/20 text-[var(--theme-accent)] dark:text-[var(--theme-soft)] text-xs font-semibold">
        Doação de bem
      </span>
      {{/if}}

      {{#if necessidade.meta_atingida}}
      <span class="px-3 py-1 rounded-full bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 text-xs font-semibold">Meta atingida</span>
      {{/if}}
      {{#if necessidade.quase_completa}}
      <span class="px-3 py-1 rounded-full bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-400 text-xs font-semibold">Quase completa</span>
      {{/if}}
    </div>

    <h1 class="text-2xl font-bold mb-6 text-slate-900 dark:text-white">{{necessidade.titulo}}</h1>

    <div class="bg-white dark:bg-[#102235] border border-slate-200 dark:border-white/10 rounded-2xl p-6 shadow-sm">

      <p class="mb-6 text-slate-700 dark:text-white/80 leading-relaxed">{{necessidade.descricao}}</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6 text-sm">
        <div>
          <span class="block text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-white/40 mb-1">ONG</span>
          <span class="font-medium text-slate-800 dark:text-white">{{necessidade.nome_ong}}</span>
        </div>
        <div>
          <span class="block text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-white/40 mb-1">Categoria</span>
          <span class="font-medium text-slate-800 dark:text-white">{{necessidade.categoria}}</span>
        </div>
        <div>
          <span class="block text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-white/40 mb-1">Status</span>
          <span class="font-medium text-slate-800 dark:text-white capitalize">{{necessidade.status}}</span>
        </div>

        {{#if necessidade.isVoluntariado}}
        {{#if necessidade.local_atividade}}
        <div>
          <span class="block text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-white/40 mb-1">Local</span>
          <span class="font-medium text-slate-800 dark:text-white capitalize">{{necessidade.local_atividade}}</span>
        </div>
        {{/if}}
        {{#if necessidade.turno}}
        <div>
          <span class="block text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-white/40 mb-1">Turno</span>
          <span class="font-medium text-slate-800 dark:text-white capitalize">{{necessidade.turno}}</span>
        </div>
        {{/if}}
        {{#if necessidade.data_inicio}}
        <div>
          <span class="block text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-white/40 mb-1">Data de início</span>
          <span class="font-medium text-slate-800 dark:text-white">{{necessidade.data_inicio}}</span>
        </div>
        {{/if}}
        {{#if necessidade.data_fim}}
        <div>
          <span class="block text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-white/40 mb-1">Data de término</span>
          <span class="font-medium text-slate-800 dark:text-white">{{necessidade.data_fim}}</span>
        </div>
        {{/if}}
        <div>
          <span class="block text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-white/40 mb-1">Vagas disponíveis</span>
          <span class="font-medium text-slate-800 dark:text-white">{{necessidade.faltante}} de {{necessidade.quantidade}}</span>
        </div>
        {{else}}
        <div>
          <span class="block text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-white/40 mb-1">Meta</span>
          <span class="font-medium text-slate-800 dark:text-white">{{necessidade.quantidade}}</span>
        </div>
        <div>
          <span class="block text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-white/40 mb-1">Recebido</span>
          <span class="font-medium text-slate-800 dark:text-white">{{necessidade.quantidade_recebida}}</span>
        </div>
        <div>
          <span class="block text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-white/40 mb-1">Faltam</span>
          <span class="font-medium text-slate-800 dark:text-white">{{necessidade.faltante}}</span>
        </div>
        {{/if}}
      </div>

      <!-- Barra de progresso -->
      <div class="mb-6">
        <div class="flex justify-between text-sm mb-1">
          <span class="font-semibold text-slate-700 dark:text-white/70">Progresso</span>
          <span class="font-semibold text-slate-700 dark:text-white/70">{{necessidade.percentual}}%</span>
        </div>
        <div class="w-full bg-slate-100 dark:bg-white/10 rounded-full h-3 overflow-hidden">
          <div class="{{#if necessidade.isVoluntariado}}bg-emerald-500{{else if necessidade.isServico}}bg-[var(--theme-accent)]{{else}}bg-[var(--theme-primary)]{{/if}} h-3 rounded-full transition-all duration-500" style="width: {{necessidade.percentual}}%;"></div>
        </div>
        <p class="text-xs mt-1.5 text-slate-500 dark:text-white/50">
          {{#if necessidade.isVoluntariado}}
            {{necessidade.quantidade_recebida}} de {{necessidade.quantidade}} vagas preenchidas
          {{else}}
            {{necessidade.quantidade_recebida}} de {{necessidade.quantidade}} recebidos
          {{/if}}
        </p>
      </div>

      <!-- CTAs -->
      {{#if isPropriaOng}}
      <div class="border-t border-slate-100 dark:border-white/10 pt-5">
        <div class="rounded-xl bg-[var(--theme-soft)] dark:bg-[var(--theme-primary)]/15 border border-[var(--theme-primary)]/20 dark:border-[var(--theme-primary)]/30 px-4 py-3">
          <p class="text-sm font-semibold text-[var(--theme-strong)] dark:text-[var(--theme-soft)]">
            Esta necessidade pertence à sua ONG.
          </p>
          <p class="text-xs text-slate-600 dark:text-white/70 mt-1">
            Para gerenciar recebimentos e status, use a tela Minhas necessidades.
          </p>
        </div>
      </div>
      {{else}}
      {{#if canRegistrarInteresse}}
      <div class="flex gap-3 flex-wrap border-t border-slate-100 dark:border-white/10 pt-5">
        {{#if necessidade.isVoluntariado}}
        <a href="/interesses/nova?necessidade_id={{necessidade.id}}"
          class="inline-flex items-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white px-5 py-3 rounded-xl font-medium transition">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          Quero ser voluntário
        </a>
        {{else}}
        <a href="/interesses/nova?necessidade_id={{necessidade.id}}"
          class="inline-flex items-center gap-2 bg-[var(--theme-primary)] hover:bg-[var(--theme-strong)] text-white px-5 py-3 rounded-xl font-medium transition">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
          {{#if necessidade.isServico}}Quero oferecer este serviço{{else}}Quero entregar este item{{/if}}
        </a>
        {{/if}}

        {{#ifCond user.tipo 'usuario'}}
        <form method="POST" action="/mensagens/iniciar" class="inline-flex">
          <input type="hidden" name="ong_id" value="{{necessidade.ong_id}}" />
          <input type="hidden" name="necessidade_id" value="{{necessidade.id}}" />
          <input type="hidden" name="mensagem" value="Olá! Tenho interesse na necessidade &quot;{{necessidade.titulo}}&quot;. Poderia me dar mais informações?" />
          <button type="submit"
            class="inline-flex items-center gap-2 border border-slate-300 dark:border-white/20 text-slate-600 dark:text-white/80 px-5 py-3 rounded-xl font-medium hover:bg-slate-50 dark:hover:bg-white/5 transition">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
            Enviar mensagem à ONG
          </button>
        </form>
        {{/ifCond}}
      </div>
      {{else if isPublicGuest}}
      <div class="border-t border-slate-100 dark:border-white/10 pt-5 space-y-4">
        <div class="rounded-xl bg-[var(--theme-soft)] dark:bg-[var(--theme-primary)]/15 border border-[var(--theme-primary)]/20 dark:border-[var(--theme-primary)]/30 px-4 py-3">
          <p class="text-sm font-semibold text-[var(--theme-strong)] dark:text-[var(--theme-soft)]">
            VocÃª pode explorar esta necessidade sem login.
          </p>
          <p class="text-xs text-slate-600 dark:text-white/70 mt-1">
            Para continuar em {{#if necessidade.isServico}}Quero oferecer este serviÃ§o{{else if necessidade.isVoluntariado}}Quero ser voluntÃ¡rio{{else}}Quero entregar este item{{/if}}, faÃ§a login ou crie sua conta.
          </p>
        </div>

        <div class="flex gap-3 flex-wrap">
          <a href="{{loginRedirectUrl}}"
            class="inline-flex items-center gap-2 bg-[var(--theme-primary)] hover:bg-[var(--theme-strong)] text-white px-5 py-3 rounded-xl font-medium transition">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            {{#if necessidade.isServico}}Quero oferecer este serviÃ§o{{else if necessidade.isVoluntariado}}Quero ser voluntÃ¡rio{{else}}Quero entregar este item{{/if}}
          </a>
          <a href="{{registerRedirectUrl}}"
            class="inline-flex items-center gap-2 border border-slate-300 dark:border-white/20 text-slate-600 dark:text-white/80 px-5 py-3 rounded-xl font-medium hover:bg-slate-50 dark:hover:bg-white/5 transition">
            Criar conta
          </a>
        </div>
      </div>
      {{/if}}
      {{/if}}

    </div>
  </div>
</section>
