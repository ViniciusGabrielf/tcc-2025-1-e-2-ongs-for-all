<div class="max-w-5xl mx-auto space-y-6">

  <!-- Cabeçalho -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
    <div>
      <h2 class="text-2xl font-bold text-[#2D4BA6] dark:text-white">Apoiadores Institucionais</h2>
      <p class="text-sm text-slate-500 dark:text-white/60 mt-0.5">Gerencie os apoiadores exibidos no rodapé da plataforma</p>
    </div>
    <a href="/admin/apoiadores/novo"
      class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-[#2D4BA6] text-white text-sm font-semibold hover:opacity-90 transition shadow-sm whitespace-nowrap">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
      </svg>
      Novo apoiador
    </a>
  </div>

  <!-- Feedback -->
  {{#if sucesso}}
  <div class="flex items-center gap-3 bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-200 dark:border-emerald-800 text-emerald-700 dark:text-emerald-300 px-4 py-3 rounded-xl text-sm font-medium">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
    </svg>
    Ação realizada com sucesso.
  </div>
  {{/if}}

  <!-- Filtros de status -->
  <div class="flex gap-1 flex-wrap">
    <a href="/admin/apoiadores?status=todos"
      class="px-3 py-1.5 rounded-lg text-xs font-semibold transition
        {{#ifCond filtroStatus '===' 'todos'}}bg-[#2D4BA6] text-white{{else}}bg-slate-100 dark:bg-white/5 text-slate-600 dark:text-white/60 hover:bg-slate-200 dark:hover:bg-white/10{{/ifCond}}">
      Todos ({{contagens.todos}})
    </a>
    <a href="/admin/apoiadores?status=ativo"
      class="px-3 py-1.5 rounded-lg text-xs font-semibold transition
        {{#ifCond filtroStatus '===' 'ativo'}}bg-emerald-500 text-white{{else}}bg-slate-100 dark:bg-white/5 text-slate-600 dark:text-white/60 hover:bg-slate-200 dark:hover:bg-white/10{{/ifCond}}">
      Ativos ({{contagens.ativo}})
    </a>
    <a href="/admin/apoiadores?status=pausado"
      class="px-3 py-1.5 rounded-lg text-xs font-semibold transition
        {{#ifCond filtroStatus '===' 'pausado'}}bg-amber-500 text-white{{else}}bg-slate-100 dark:bg-white/5 text-slate-600 dark:text-white/60 hover:bg-slate-200 dark:hover:bg-white/10{{/ifCond}}">
      Pausados ({{contagens.pausado}})
    </a>
    <a href="/admin/apoiadores?status=encerrado"
      class="px-3 py-1.5 rounded-lg text-xs font-semibold transition
        {{#ifCond filtroStatus '===' 'encerrado'}}bg-slate-500 text-white{{else}}bg-slate-100 dark:bg-white/5 text-slate-600 dark:text-white/60 hover:bg-slate-200 dark:hover:bg-white/10{{/ifCond}}">
      Encerrados ({{contagens.encerrado}})
    </a>
  </div>

  <!-- Lista -->
  {{#if apoiadores.length}}
  <div class="space-y-3">
    {{#each apoiadores}}
    <div class="bg-white dark:bg-[#102235] border border-slate-200 dark:border-white/10 rounded-2xl p-5 shadow-sm">
      <div class="flex flex-col md:flex-row md:items-center gap-4">

        <!-- Logo -->
        <div class="w-14 h-14 rounded-xl bg-slate-100 dark:bg-white/5 flex items-center justify-center shrink-0 overflow-hidden border border-slate-200 dark:border-white/10">
          {{#if logo_url}}
          <img src="{{logo_url}}" alt="{{nome}}" class="w-full h-full object-contain p-1" />
          {{else}}
          <span class="text-lg font-bold text-slate-400 dark:text-white/30">{{nome.[0]}}</span>
          {{/if}}
        </div>

        <!-- Info -->
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 flex-wrap mb-1">
            <span class="font-bold text-slate-800 dark:text-white text-sm truncate">{{nome}}</span>
            {{#if isAtivo}}
            <span class="px-2 py-0.5 rounded-full bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-300 text-xs font-semibold">Ativo</span>
            {{else if isPausado}}
            <span class="px-2 py-0.5 rounded-full bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-300 text-xs font-semibold">Pausado</span>
            {{else}}
            <span class="px-2 py-0.5 rounded-full bg-slate-100 text-slate-500 dark:bg-white/10 dark:text-white/40 text-xs font-semibold">Encerrado</span>
            {{/if}}
            <span class="px-2 py-0.5 rounded-full bg-[#2D4BA6]/10 text-[#2D4BA6] dark:bg-[#4886D9]/20 dark:text-[#4886D9] text-xs font-semibold">Apoiador</span>
          </div>
          <p class="text-xs text-slate-400 dark:text-white/40">
            {{valorFormatado}}/mês · Início: {{data_inicio}}{{#if data_fim}} · Término: {{data_fim}}{{/if}}
          </p>
          {{#if descricao}}
          <p class="text-xs text-slate-500 dark:text-white/50 mt-1 truncate">{{descricao}}</p>
          {{/if}}
          {{#if website_url}}
          <a href="{{website_url}}" target="_blank" rel="noopener noreferrer"
            class="text-xs text-[#4886D9] hover:underline truncate block mt-1">{{website_url}}</a>
          {{/if}}
        </div>

        <!-- Ações -->
        <div class="flex flex-wrap gap-2 shrink-0">
          <a href="/admin/apoiadores/{{id}}/editar"
            class="px-3 py-1.5 rounded-lg text-xs font-semibold bg-slate-100 dark:bg-white/5 text-slate-600 dark:text-white/70 hover:bg-slate-200 dark:hover:bg-white/10 transition">
            Editar
          </a>
          {{#if isPausado}}
          <form method="POST" action="/admin/apoiadores/{{id}}/ativar">
            <button type="submit" class="px-3 py-1.5 rounded-lg text-xs font-semibold bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-300 hover:opacity-80 transition">
              Ativar
            </button>
          </form>
          {{/if}}
          {{#if isAtivo}}
          <form method="POST" action="/admin/apoiadores/{{id}}/pausar">
            <button type="submit" class="px-3 py-1.5 rounded-lg text-xs font-semibold bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-300 hover:opacity-80 transition">
              Pausar
            </button>
          </form>
          {{/if}}
          {{#unless isEncerrado}}
          <form method="POST" action="/admin/apoiadores/{{id}}/encerrar"
            onsubmit="return confirm('Encerrar este apoiador? Esta ação não pode ser desfeita.')">
            <button type="submit" class="px-3 py-1.5 rounded-lg text-xs font-semibold bg-red-100 text-red-600 dark:bg-red-900/30 dark:text-red-400 hover:opacity-80 transition">
              Encerrar
            </button>
          </form>
          {{/unless}}
        </div>

      </div>
    </div>
    {{/each}}
  </div>
  {{else}}
  <div class="bg-white dark:bg-[#102235] border border-slate-200 dark:border-white/10 rounded-2xl p-10 text-center shadow-sm">
    <p class="text-slate-400 dark:text-white/40 text-sm">Nenhum apoiador encontrado para os filtros selecionados.</p>
    <a href="/admin/apoiadores/novo" class="inline-block mt-3 text-sm text-[#4886D9] hover:underline">Cadastrar primeiro apoiador</a>
  </div>
  {{/if}}

</div>
