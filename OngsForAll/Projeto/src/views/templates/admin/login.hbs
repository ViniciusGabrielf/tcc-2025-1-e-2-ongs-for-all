<div class="min-h-screen flex items-center justify-center px-4">
  <div class="w-full max-w-sm">

    <div class="text-center mb-8">
      <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-[#1D3273] to-[#2D4BA6] flex items-center justify-center mx-auto mb-4 shadow-lg">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
      </div>
      <h1 class="text-2xl font-bold text-[#1D3273] dark:text-white">Administração</h1>
      <p class="text-sm text-slate-500 dark:text-white/50 mt-1">ONGs For All — Painel admin</p>
    </div>

    {{#if error}}
    <div class="bg-red-50 border border-red-200 text-red-700 p-3 rounded-xl mb-4 text-sm text-center">{{error}}</div>
    {{/if}}

    <div class="bg-white dark:bg-[#1D3273]/20 border border-slate-200 dark:border-white/10 rounded-2xl p-6 shadow-sm">
      <form method="POST" action="/admin/login" class="space-y-4">
        <div>
          <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">Chave de acesso</label>
          <input type="password" name="secret" required autofocus
            class="w-full rounded-xl p-3 border border-slate-200 dark:border-white/10 bg-white dark:bg-[#1a3050] text-slate-900 dark:text-white placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-[#1D3273]"
            placeholder="••••••••••••" />
        </div>
        <button type="submit"
          class="w-full bg-gradient-to-r from-[#1D3273] to-[#2D4BA6] hover:opacity-90 text-white py-3 rounded-xl font-semibold transition shadow">
          Acessar painel
        </button>
      </form>
    </div>

  </div>
</div>
