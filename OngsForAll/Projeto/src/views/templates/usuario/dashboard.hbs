<section id="dashboard" class="min-h-screen">
  <div class="max-w-7xl mx-auto space-y-10">

    {{#if sucessoInteresse}}
    <div class="flex items-center gap-3 bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-200 dark:border-emerald-800 text-emerald-700 dark:text-emerald-300 px-4 py-3 rounded-xl text-sm font-medium">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
      </svg>
      Interesse registrado com sucesso! A ONG será notificada.
    </div>
    {{/if}}

    <!-- Hero -->
    <div class="relative overflow-hidden rounded-2xl bg-gradient-to-r from-[#4886D9] to-pink-500 p-6 sm:p-10 shadow-lg">
      <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg%20width%3D%2260%22%20height%3D%2260%22%20viewBox%3D%220%200%2060%2060%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cg%20fill%3D%22none%22%20fill-rule%3D%22evenodd%22%3E%3Cg%20fill%3D%22%23ffffff%22%20fill-opacity%3D%220.05%22%3E%3Cpath%20d%3D%22M36%2034v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6%2034v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6%204V0H4v4H0v2h4v4h2V6h4V4H6z%22%2F%3E%3C%2Fg%3E%3C%2Fg%3E%3C%2Fsvg%3E')] opacity-50"></div>
      <div class="relative">
        <h1 class="text-2xl sm:text-4xl font-extrabold text-white break-words">
          Bem-vindo, {{user.nome}}!
        </h1>
        <p class="mt-2 text-white/80 text-lg">Veja suas estatísticas e acompanhe seu impacto</p>
      </div>
    </div>

    <!-- Filtro por período -->
    <div>
      <button type="button" id="btn-toggle-filtro"
        class="inline-flex items-center gap-2 bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-full px-5 py-2.5 shadow-sm text-sm font-semibold text-[#2D4BA6] dark:text-white hover:shadow-md transition-all duration-200">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
        </svg>
        Filtrar por período
        <svg xmlns="http://www.w3.org/2000/svg" id="filtro-chevron" class="w-4 h-4 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </button>

      <form method="GET" action="/dashboard" id="filtro-form"
        class="hidden mt-3 bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-2xl p-5 shadow-sm flex-col sm:flex-row items-end gap-4">
        <div class="flex flex-col flex-1 min-w-0">
          <label class="text-sm font-semibold mb-1 text-slate-600 dark:text-white/70">De</label>
          <input type="date" name="de" value="{{filtroDe}}"
            class="border border-slate-200 dark:border-white/15 rounded-xl px-3 py-2 text-sm bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-[#4886D9] w-full" />
        </div>
        <div class="flex flex-col flex-1 min-w-0">
          <label class="text-sm font-semibold mb-1 text-slate-600 dark:text-white/70">Até</label>
          <input type="date" name="ate" value="{{filtroAte}}"
            class="border border-slate-200 dark:border-white/15 rounded-xl px-3 py-2 text-sm bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-[#4886D9] w-full" />
        </div>
        <div class="flex flex-col sm:flex-row gap-2 w-full sm:w-auto">
          <button type="submit"
            class="bg-gradient-to-r from-[#4886D9] to-[#2D4BA6] text-white px-5 py-2 rounded-full text-sm font-semibold hover:opacity-90 transition shadow-sm">
            Filtrar
          </button>
          <a href="/dashboard"
            class="border border-slate-200 dark:border-white/15 px-5 py-2 rounded-full text-sm font-semibold hover:opacity-80 transition text-slate-600 dark:text-white/70">
            Limpar
          </a>
        </div>
      </form>
    </div>

    <!-- KPIs -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="bg-white dark:bg-white/5 p-6 rounded-2xl border border-slate-200 dark:border-white/10 shadow-sm border-l-4 border-l-[#4886D9] hover:shadow-md transition-shadow duration-200">
        <p class="text-sm text-slate-500 dark:text-white/60">Interesses criados</p>
        <p class="text-3xl font-extrabold text-[#2D4BA6] dark:text-white mt-1">{{totalInteresses}}</p>
      </div>

      <div class="bg-white dark:bg-white/5 p-6 rounded-2xl border border-slate-200 dark:border-white/10 shadow-sm border-l-4 border-l-[#2D4BA6] hover:shadow-md transition-shadow duration-200">
        <p class="text-sm text-slate-500 dark:text-white/60">Categorias apoiadas</p>
        <p class="text-3xl font-extrabold text-[#2D4BA6] dark:text-white mt-1">{{qtdTipos}}</p>
      </div>

      <div class="bg-white dark:bg-white/5 p-6 rounded-2xl border border-slate-200 dark:border-white/10 shadow-sm border-l-4 border-l-pink-500 hover:shadow-md transition-shadow duration-200">
        <p class="text-sm text-slate-500 dark:text-white/60">Meses com atividade</p>
        <p class="text-3xl font-extrabold text-[#2D4BA6] dark:text-white mt-1">{{qtdMesesComAtividade}}</p>
      </div>
    </div>

    <!-- Métricas de Impacto -->
    <div>
      <h2 class="text-2xl font-bold mb-4 bg-gradient-to-r from-[#2D4BA6] to-[#4886D9] dark:from-white dark:to-white/80 text-transparent bg-clip-text">Seu impacto</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

        <div class="bg-white dark:bg-white/5 p-6 rounded-2xl border border-slate-200 dark:border-white/10 shadow-sm hover:shadow-md transition-all duration-200">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-11 h-11 rounded-full bg-gradient-to-br from-[#4886D9]/20 to-[#2D4BA6]/10 dark:from-[#4886D9]/30 dark:to-[#2D4BA6]/20 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[#2D4BA6] dark:text-[#4886D9]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
              </svg>
            </div>
            <p class="text-sm font-semibold text-slate-500 dark:text-white/60">Necessidades apoiadas</p>
          </div>
          <p class="text-3xl font-extrabold text-[#2D4BA6] dark:text-white">{{necessidadesApoiadas}}</p>
        </div>

        <div class="bg-white dark:bg-white/5 p-6 rounded-2xl border border-slate-200 dark:border-white/10 shadow-sm hover:shadow-md transition-all duration-200">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-11 h-11 rounded-full bg-gradient-to-br from-[#4886D9]/20 to-[#2D4BA6]/10 dark:from-[#4886D9]/30 dark:to-[#2D4BA6]/20 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[#2D4BA6] dark:text-[#4886D9]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <p class="text-sm font-semibold text-slate-500 dark:text-white/60">ONGs apoiadas</p>
          </div>
          <p class="text-3xl font-extrabold text-[#2D4BA6] dark:text-white">{{ongsApoiadas}}</p>
        </div>

        <div class="bg-white dark:bg-white/5 p-6 rounded-2xl border border-slate-200 dark:border-white/10 shadow-sm hover:shadow-md transition-all duration-200">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-11 h-11 rounded-full bg-gradient-to-br from-[#4886D9]/20 to-[#2D4BA6]/10 dark:from-[#4886D9]/30 dark:to-[#2D4BA6]/20 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[#2D4BA6] dark:text-[#4886D9]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
              </svg>
            </div>
            <p class="text-sm font-semibold text-slate-500 dark:text-white/60">Interesses criados</p>
          </div>
          <p class="text-3xl font-extrabold text-[#2D4BA6] dark:text-white">{{interessesCriados}}</p>
        </div>

        <div class="bg-white dark:bg-white/5 p-6 rounded-2xl border border-slate-200 dark:border-white/10 shadow-sm hover:shadow-md transition-all duration-200">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-11 h-11 rounded-full bg-gradient-to-br from-[#4886D9]/20 to-[#2D4BA6]/10 dark:from-[#4886D9]/30 dark:to-[#2D4BA6]/20 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[#2D4BA6] dark:text-[#4886D9]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <p class="text-sm font-semibold text-slate-500 dark:text-white/60">Entregas confirmadas</p>
          </div>
          <p class="text-3xl font-extrabold text-[#2D4BA6] dark:text-white">{{interessesRecebidos}}</p>
        </div>
      </div>

      <!-- Card de impacto resumido -->
      {{#if necessidadesApoiadas}}
      <div class="mt-6 bg-gradient-to-r from-[#4886D9] to-pink-500 p-5 sm:p-6 rounded-2xl shadow-lg text-white">
        <div class="flex flex-col sm:flex-row sm:items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
          </svg>
          <p class="text-lg font-bold">
            Você já ajudou {{necessidadesApoiadas}} necessidade(s) e apoiou {{ongsApoiadas}} ONG(s)!
          </p>
        </div>
      </div>
      {{/if}}
    </div>

    <!-- Gamificação -->
    {{#if gamificacao}}
    <div class="bg-white dark:bg-[#102235] border border-slate-200 dark:border-white/10 rounded-2xl shadow-sm p-6">
      <div class="flex items-center justify-between mb-5">
        <div>
          <h2 class="text-base font-bold text-[#2D4BA6] dark:text-white">Sua jornada</h2>
          <p class="text-xs text-slate-500 dark:text-white/50 mt-0.5">Nível {{gamificacao.nivel}} — {{gamificacao.nivelLabel}}</p>
        </div>
        <div class="text-right">
          <p class="text-2xl font-extrabold text-[#2D4BA6] dark:text-white">{{gamificacao.totalAcumulado}} <span class="text-sm font-medium text-slate-400">XP</span></p>
        </div>
      </div>

      <!-- Barra de progresso XP -->
      <div class="mb-5">
        <div class="flex justify-between text-xs text-slate-500 dark:text-white/50 mb-1.5">
          <span>Progresso para nível {{gamificacao.nivel}}</span>
          <span>{{gamificacao.progressoXP}}%</span>
        </div>
        <div class="h-2 bg-slate-100 dark:bg-white/10 rounded-full overflow-hidden">
          <div class="h-full bg-gradient-to-r from-[#4886D9] to-[#2D4BA6] rounded-full transition-all duration-700"
            style="width: {{gamificacao.progressoXP}}%"></div>
        </div>
      </div>

      <!-- Selos -->
      {{#if gamificacao.temSelos}}
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-white/40 mb-3">Conquistas</p>
        <div class="flex flex-wrap gap-2">
          {{#each gamificacao.selos}}
          <div class="group relative">
            <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-[#2D4BA6]/10 dark:bg-[#4886D9]/20 border border-[#4886D9]/20 dark:border-[#4886D9]/40">
              <span class="text-base">{{icone}}</span>
              <span class="text-xs font-semibold text-[#2D4BA6] dark:text-white">{{nome}}</span>
            </div>
            <!-- Tooltip -->
            <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 hidden group-hover:block z-10 w-44 bg-slate-800 dark:bg-slate-900 text-white text-xs rounded-xl px-3 py-2 shadow-lg text-center">
              {{descricao}}
              <div class="text-slate-400 mt-0.5">{{conquistado_em}}</div>
            </div>
          </div>
          {{/each}}
        </div>
      </div>
      {{else}}
      <p class="text-sm text-slate-400 dark:text-white/30">Complete ações para ganhar conquistas!</p>
      {{/if}}
    </div>
    {{/if}}

    <!-- Gráficos -->
    <div id="chartsWrap" class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="min-w-0 overflow-hidden bg-white dark:bg-white/5 p-4 sm:p-6 rounded-2xl border border-slate-200 dark:border-white/10 shadow-sm">
        <h2 class="text-center font-semibold mb-4 text-slate-700 dark:text-white">ONGs apoiadas (por mês)</h2>
        <div class="relative h-56 sm:h-64 min-w-0">
          <canvas id="ongsChart"></canvas>
        </div>
      </div>

      <div class="min-w-0 overflow-hidden bg-white dark:bg-white/5 p-4 sm:p-6 rounded-2xl border border-slate-200 dark:border-white/10 shadow-sm">
        <h2 class="text-center font-semibold mb-4 text-slate-700 dark:text-white">Interesses por mês</h2>
        <div class="relative h-56 sm:h-64 min-w-0">
          <canvas id="graficoInteressesMes"></canvas>
        </div>
      </div>

      <div class="min-w-0 overflow-hidden bg-white dark:bg-white/5 p-4 sm:p-6 rounded-2xl border border-slate-200 dark:border-white/10 shadow-sm">
        <h2 class="text-center font-semibold mb-4 text-slate-700 dark:text-white">Contribuições por tipo</h2>
        <div class="relative h-56 sm:h-64 min-w-0">
          <canvas id="categoriasChart"></canvas>
        </div>
      </div>
    </div>

    <!-- Atividades Recentes -->
    <div class="bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-2xl p-4 sm:p-6 shadow-sm">
      <h2 class="text-2xl font-bold mb-4 bg-gradient-to-r from-[#2D4BA6] to-[#4886D9] dark:from-white dark:to-white/80 text-transparent bg-clip-text">Atividades recentes</h2>

      {{#if atividadesRecentes.length}}
      <div class="space-y-3 max-h-80 overflow-y-auto pr-1">
        {{#each atividadesRecentes}}
        <div class="flex items-start gap-4 p-4 rounded-xl bg-slate-50 dark:bg-white/5 border border-slate-100 dark:border-white/5 hover:bg-slate-100 dark:hover:bg-white/10 hover:shadow-sm transition-all duration-200">
          <div class="shrink-0 mt-0.5">
            {{#ifCond this.tipo_atividade '==' 'interesse_pendente'}}
            <div class="w-9 h-9 rounded-full bg-amber-100 dark:bg-amber-500/20 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-amber-600 dark:text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            {{/ifCond}}
            {{#ifCond this.tipo_atividade '==' 'interesse_aceito'}}
            <div class="w-9 h-9 rounded-full bg-blue-100 dark:bg-blue-500/20 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#2D4BA6] dark:text-[#4886D9]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5" />
              </svg>
            </div>
            {{/ifCond}}
            {{#ifCond this.tipo_atividade '==' 'interesse_recebido'}}
            <div class="w-9 h-9 rounded-full bg-emerald-100 dark:bg-emerald-500/20 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-emerald-600 dark:text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            {{/ifCond}}
            {{#ifCond this.tipo_atividade '==' 'interesse_cancelado'}}
            <div class="w-9 h-9 rounded-full bg-red-100 dark:bg-red-500/20 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-red-600 dark:text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            {{/ifCond}}
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-slate-700 dark:text-white">{{this.descricao}}</p>
            <p class="text-xs text-slate-400 dark:text-white/40 mt-1">
              {{this.data_atividade}}
            </p>
          </div>
        </div>
        {{/each}}
      </div>
      {{else}}
      <p class="text-center text-slate-400 dark:text-white/50 py-6">
        Nenhuma atividade recente encontrada.
      </p>
      {{/if}}
    </div>

  </div>

  <script>
    // Toggle filtro
    (function () {
      const btn = document.getElementById('btn-toggle-filtro');
      const form = document.getElementById('filtro-form');
      const chevron = document.getElementById('filtro-chevron');
      if (!btn || !form) return;

      // Abrir automaticamente se já houver filtro ativo
      const filtroDe = '{{filtroDe}}';
      const filtroAte = '{{filtroAte}}';
      if (filtroDe || filtroAte) {
        form.classList.remove('hidden');
        form.classList.add('flex');
        if (chevron) chevron.style.transform = 'rotate(180deg)';
      }

      btn.addEventListener('click', function () {
        const aberto = !form.classList.contains('hidden');
        if (aberto) {
          form.classList.add('hidden');
          form.classList.remove('flex');
          if (chevron) chevron.style.transform = '';
        } else {
          form.classList.remove('hidden');
          form.classList.add('flex');
          if (chevron) chevron.style.transform = 'rotate(180deg)';
        }
      });
    })();

    // Validação de datas do filtro
    (function () {
      var filtroForm = document.getElementById('filtro-form');
      var inputDe = filtroForm && filtroForm.querySelector('input[name="de"]');
      var inputAte = filtroForm && filtroForm.querySelector('input[name="ate"]');
      if (!inputDe || !inputAte) return;

      inputDe.addEventListener('change', function () {
        if (inputDe.value) {
          inputAte.min = inputDe.value;
          if (inputAte.value && inputAte.value < inputDe.value) inputAte.value = '';
        } else {
          inputAte.min = '';
        }
      });

      inputAte.addEventListener('change', function () {
        if (inputAte.value) {
          inputDe.max = inputAte.value;
          if (inputDe.value && inputDe.value > inputAte.value) inputDe.value = '';
        } else {
          inputDe.max = '';
        }
      });

      // Aplicar limites iniciais se já houver valores
      if (inputDe.value) inputAte.min = inputDe.value;
      if (inputAte.value) inputDe.max = inputAte.value;
    })();

    // Toast de sucesso
    (function () {
      const urlParams = new URLSearchParams(window.location.search);
      if (urlParams.get('sucesso') === '1') {
        const toast = document.createElement('div');
        toast.id = 'toast';
        toast.className = 'fixed top-5 right-5 bg-green-500 text-white px-6 py-3 rounded-xl shadow-lg z-50';
        toast.textContent = 'Interesse registrado com sucesso!';
        document.body.appendChild(toast);

        setTimeout(() => {
          toast.remove();
          const url = new URL(window.location.href);
          url.searchParams.delete('sucesso');
          window.history.replaceState({}, document.title, url.toString());
        }, 3000);
      }
    })();

    // Dados vindos do servidor
    const labelsMes = {{{ labelsMes }}};
    const valoresInteressesMes = {{{ valoresInteressesMes }}};
    const valoresOngsMes = {{{ valoresOngsMes }}};
    const labelsTipo = {{{ labelsTipo }}};
    const valoresTipo = {{{ valoresTipo }}};

    const hasData =
      (Array.isArray(valoresInteressesMes) && valoresInteressesMes.length > 0 && valoresInteressesMes.some(v => Number(v) > 0)) ||
      (Array.isArray(valoresTipo) && valoresTipo.length > 0 && valoresTipo.some(v => Number(v) > 0));

    const html = document.documentElement;
    const getTextColor = () => html.classList.contains('dark') ? '#FFFFFF' : '#2D4BA6';
    const getGridColor = () => html.classList.contains('dark') ? 'rgba(255,255,255,0.1)' : 'rgba(45,75,166,0.1)';

    let chartOngs = null;
    let chartMes = null;
    let chartTipos = null;

    function destroyCharts() {
      if (chartOngs) chartOngs.destroy();
      if (chartMes) chartMes.destroy();
      if (chartTipos) chartTipos.destroy();
      chartOngs = chartMes = chartTipos = null;
    }

    function renderCharts() {
      destroyCharts();

      const baseOptions = {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { labels: { color: getTextColor() } }
        },
        scales: {
          x: { ticks: { color: getTextColor() }, grid: { color: getGridColor() } },
          y: { ticks: { color: getTextColor() }, grid: { color: getGridColor() } }
        }
      };

      const lineOptions = {
        ...baseOptions,
        scales: {
          ...baseOptions.scales,
          y: {
            beginAtZero: true,
            ticks: { color: getTextColor(), precision: 0 },
            grid: { color: getGridColor() }
          }
        }
      };

      const barOptions = {
        ...baseOptions,
        scales: {
          ...baseOptions.scales,
          y: {
            beginAtZero: true,
            ticks: {
              color: getTextColor(),
              stepSize: 10,
              callback: (value) => Number(value).toFixed(0)
            },
            grid: { color: getGridColor() }
          }
        },
        plugins: {
          ...baseOptions.plugins,
          tooltip: {
            callbacks: {
              label: (ctx) => {
                const v = Number(ctx.raw || 0);
                return 'Interesses: ' + v;
              }
            }
          }
        }
      };

      const ongsCanvas = document.getElementById('ongsChart');
      const barrasCanvas = document.getElementById('graficoInteressesMes');
      const tiposCanvas = document.getElementById('categoriasChart');

      if (!ongsCanvas || !barrasCanvas || !tiposCanvas) return;

      chartOngs = new Chart(ongsCanvas, {
        type: 'line',
        data: {
          labels: labelsMes,
          datasets: [{
            label: 'ONGs apoiadas',
            data: valoresOngsMes,
            borderColor: '#4886D9',
            backgroundColor: 'rgba(72,134,217,0.15)',
            fill: true,
            tension: 0.4
          }]
        },
        options: lineOptions
      });

      chartMes = new Chart(barrasCanvas, {
        type: 'bar',
        data: {
          labels: labelsMes,
          datasets: [{
            label: 'Interesses por mês',
            data: valoresInteressesMes,
            backgroundColor: '#2D4BA6',
            borderRadius: 8
          }]
        },
        options: barOptions
      });

      chartTipos = new Chart(tiposCanvas, {
        type: 'doughnut',
        data: {
          labels: labelsTipo,
          datasets: [{
            data: valoresTipo,
            backgroundColor: ['#4886D9', '#E83FBA', '#2D4BA6', '#F59E0B']
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { labels: { color: getTextColor() } } }
        }
      });
    }

    document.addEventListener('DOMContentLoaded', () => {
      if (!hasData) {
        const wrap = document.getElementById("chartsWrap");
        if (wrap) {
          wrap.innerHTML =
            '<div class="md:col-span-3 bg-white dark:bg-white/5 p-8 rounded-2xl border border-slate-200 dark:border-white/10 shadow-sm text-center">' +
            '<h2 class="text-xl font-bold mb-2">Sem dados ainda</h2>' +
            '<p class="text-slate-400 dark:text-white/50 mb-6">Demonstre interesse em uma necessidade para começar a acompanhar seu impacto.</p>' +
            '<a href="/necessidades" class="inline-block bg-gradient-to-r from-[#4886D9] to-[#2D4BA6] text-white font-bold px-6 py-3 rounded-xl shadow hover:opacity-90 transition">Explorar necessidades</a>' +
            '</div>';
        }
        return;
      }

      renderCharts();
    });

    window.addEventListener('theme:changed', () => {
      destroyCharts();
      renderCharts();
    });
  </script>
</section>
