<section id="dashboard" class="min-h-screen">
  <div class="max-w-4xl mx-auto space-y-8">

    {{#if sucessoInteresse}}
    <div class="flex items-center gap-3 bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-200 dark:border-emerald-800 text-emerald-700 dark:text-emerald-300 px-4 py-3 rounded-xl text-sm font-medium">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
      </svg>
      Interesse registrado com sucesso! A ONG será notificada.
    </div>
    {{/if}}

    <!-- Hero -->
    <div class="relative overflow-hidden rounded-2xl bg-gradient-to-r from-[#4886D9] to-pink-500 p-6 sm:p-10 shadow-lg">
      <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg%20width%3D%2260%22%20height%3D%2260%22%20viewBox%3D%220%200%2060%2060%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cg%20fill%3D%22none%22%20fill-rule%3D%22evenodd%22%3E%3Cg%20fill%3D%22%23ffffff%22%20fill-opacity%3D%220.05%22%3E%3Cpath%20d%3D%22M36%2034v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6%2034v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6%204V0H4v4H0v2h4v4h2V6h4V4H6z%22%2F%3E%3C%2Fg%3E%3C%2Fg%3E%3C%2Fsvg%3E')] opacity-50"></div>
      <div class="relative flex items-end justify-between gap-4 flex-wrap">
        <div>
          <h1 class="text-2xl sm:text-4xl font-extrabold text-white break-words">
            Bem-vindo, {{user.nome}}!
          </h1>
          <p class="mt-2 text-white/80 text-lg">Acompanhe seu histórico de atividades e impacto</p>
        </div>
        <span class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-white/20 text-white text-sm font-bold shrink-0">
          {{total}} {{#if isTabTodos}}interesses{{else}}resultado(s){{/if}}
        </span>
      </div>
    </div>

    <!-- Cards de resumo -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      <a href="/dashboard?status=pendente" class="group bg-white dark:bg-white/5 p-4 rounded-2xl border border-slate-200 dark:border-white/10 shadow-sm hover:shadow-md transition-all duration-200 border-l-4 border-l-amber-400">
        <p class="text-xs font-semibold text-slate-500 dark:text-white/50 mb-1">Pendentes</p>
        <p class="text-3xl font-extrabold text-slate-800 dark:text-white">{{resumo.pendentes}}</p>
      </a>
      <a href="/dashboard?status=aceito" class="group bg-white dark:bg-white/5 p-4 rounded-2xl border border-slate-200 dark:border-white/10 shadow-sm hover:shadow-md transition-all duration-200 border-l-4 border-l-blue-500">
        <p class="text-xs font-semibold text-slate-500 dark:text-white/50 mb-1">Em andamento</p>
        <p class="text-3xl font-extrabold text-slate-800 dark:text-white">{{resumo.em_andamento}}</p>
      </a>
      <a href="/dashboard?status=recebido" class="group bg-white dark:bg-white/5 p-4 rounded-2xl border border-slate-200 dark:border-white/10 shadow-sm hover:shadow-md transition-all duration-200 border-l-4 border-l-emerald-500">
        <p class="text-xs font-semibold text-slate-500 dark:text-white/50 mb-1">Concluídas</p>
        <p class="text-3xl font-extrabold text-slate-800 dark:text-white">{{resumo.concluidas}}</p>
      </a>
      <a href="/dashboard?status=cancelado" class="group bg-white dark:bg-white/5 p-4 rounded-2xl border border-slate-200 dark:border-white/10 shadow-sm hover:shadow-md transition-all duration-200 border-l-4 border-l-red-400">
        <p class="text-xs font-semibold text-slate-500 dark:text-white/50 mb-1">Cancelados</p>
        <p class="text-3xl font-extrabold text-slate-800 dark:text-white">{{resumo.canceladas}}</p>
      </a>
    </div>

    <!-- Abas de filtro + busca -->
    <div class="flex items-center gap-1 flex-wrap">
      <a href="/dashboard{{#if buscaAtual}}?busca={{buscaAtual}}{{/if}}"
        class="shrink-0 px-4 py-2 rounded-full text-sm font-semibold transition-all duration-200
          {{#if isTabTodos}}bg-[#2D4BA6] text-white shadow-sm{{else}}bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 text-slate-600 dark:text-white/60 hover:shadow-sm{{/if}}">
        Todos
      </a>
      <a href="/dashboard?status=pendente{{#if buscaAtual}}&busca={{buscaAtual}}{{/if}}"
        class="shrink-0 px-4 py-2 rounded-full text-sm font-semibold transition-all duration-200
          {{#if isTabPendentes}}bg-amber-500 text-white shadow-sm{{else}}bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 text-slate-600 dark:text-white/60 hover:shadow-sm{{/if}}">
        Pendentes
      </a>
      <a href="/dashboard?status=aceito{{#if buscaAtual}}&busca={{buscaAtual}}{{/if}}"
        class="shrink-0 px-4 py-2 rounded-full text-sm font-semibold transition-all duration-200
          {{#if isTabAndamento}}bg-blue-600 text-white shadow-sm{{else}}bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 text-slate-600 dark:text-white/60 hover:shadow-sm{{/if}}">
        Em andamento
      </a>
      <a href="/dashboard?status=recebido{{#if buscaAtual}}&busca={{buscaAtual}}{{/if}}"
        class="shrink-0 px-4 py-2 rounded-full text-sm font-semibold transition-all duration-200
          {{#if isTabConcluidas}}bg-emerald-600 text-white shadow-sm{{else}}bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 text-slate-600 dark:text-white/60 hover:shadow-sm{{/if}}">
        Concluídas
      </a>
      <a href="/dashboard?status=cancelado{{#if buscaAtual}}&busca={{buscaAtual}}{{/if}}"
        class="shrink-0 px-4 py-2 rounded-full text-sm font-semibold transition-all duration-200
          {{#if isTabCancelados}}bg-red-500 text-white shadow-sm{{else}}bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 text-slate-600 dark:text-white/60 hover:shadow-sm{{/if}}">
        Cancelados
      </a>

      <form method="GET" action="/dashboard" class="ml-auto flex items-center gap-1.5 shrink-0">
        {{#if statusFiltro}}<input type="hidden" name="status" value="{{statusFiltro}}" />{{/if}}
        <input
          type="text"
          name="busca"
          value="{{buscaAtual}}"
          placeholder="Título ou ONG..."
          class="px-3 py-2 rounded-full border border-slate-200 dark:border-white/10 bg-white dark:bg-white/5 text-slate-900 dark:text-white text-xs placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-[#4886D9] w-40 transition"
        />
        <button type="submit"
          class="shrink-0 p-2 rounded-full border border-slate-200 dark:border-white/10 bg-white dark:bg-white/5 text-slate-500 dark:text-white/50 hover:text-[#4886D9] hover:border-[#4886D9]/40 transition">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </button>
        {{#if buscaAtual}}
        <a href="/dashboard{{#if statusFiltro}}?status={{statusFiltro}}{{/if}}"
          class="shrink-0 p-2 rounded-full border border-slate-200 dark:border-white/10 text-slate-400 hover:text-red-500 hover:border-red-300 transition"
          title="Limpar busca">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </a>
        {{/if}}
      </form>
    </div>

    <!-- Lista de atividades -->
    {{#if atividades.length}}
    <div class="space-y-3">
      {{#each atividades}}
      <div class="bg-white dark:bg-white/[0.04] border border-slate-200 dark:border-white/8 rounded-2xl overflow-hidden shadow-sm hover:shadow-md hover:-translate-y-px transition-all duration-200
        {{#if isPendente}}border-l-[3px] border-l-amber-400{{/if}}
        {{#if isAceito}}border-l-[3px] border-l-blue-500{{/if}}
        {{#if isRecebido}}border-l-[3px] border-l-emerald-500{{/if}}
        {{#if isCancelado}}border-l-[3px] border-l-red-400{{/if}}
      ">
        <div class="flex items-start gap-4 p-4 sm:p-5">

          <div class="shrink-0 mt-0.5">
            {{#if tipoIsBem}}
            <div class="w-10 h-10 rounded-xl bg-blue-100 dark:bg-blue-500/15 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-600 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
              </svg>
            </div>
            {{/if}}
            {{#if tipoIsServico}}
            <div class="w-10 h-10 rounded-xl bg-violet-100 dark:bg-violet-500/15 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-violet-600 dark:text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            {{/if}}
            {{#if tipoIsVoluntariado}}
            <div class="w-10 h-10 rounded-xl bg-emerald-100 dark:bg-emerald-500/15 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-emerald-600 dark:text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            {{/if}}
          </div>

          <div class="flex-1 min-w-0">
            <div class="flex items-start justify-between gap-3 flex-wrap">
              <div class="min-w-0">
                <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 dark:text-white/40 mb-0.5">{{tipoLabel}}</p>
                <p class="font-bold text-slate-800 dark:text-white text-sm sm:text-[15px] leading-snug">{{titulo}}</p>
                <p class="text-xs text-slate-500 dark:text-white/50 mt-0.5">{{subtitulo}}</p>
                <p class="text-xs text-slate-400 dark:text-white/30 mt-0.5 font-mono">#{{id}}</p>
              </div>
              <span class="shrink-0 px-2.5 py-1 rounded-full text-xs font-bold
                {{#if isPendente}}bg-amber-100 text-amber-700 dark:bg-amber-500/20 dark:text-amber-300{{/if}}
                {{#if isAceito}}bg-blue-100 text-blue-700 dark:bg-blue-500/20 dark:text-blue-300{{/if}}
                {{#if isRecebido}}bg-emerald-100 text-emerald-700 dark:bg-emerald-500/20 dark:text-emerald-300{{/if}}
                {{#if isCancelado}}bg-red-100 text-red-700 dark:bg-red-500/20 dark:text-red-300{{/if}}
              ">{{statusLabel}}</span>
            </div>

            <div class="mt-3 flex flex-wrap gap-x-4 gap-y-1.5 text-xs text-slate-500 dark:text-white/40">
              {{#if data_prevista}}
              <span class="flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                Entrega: {{data_prevista}}
              </span>
              {{/if}}
              {{#if data_inicio}}
              <span class="flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                Início: {{data_inicio}}
              </span>
              {{/if}}
              {{#if data_fim}}
              <span class="flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                Término: {{data_fim}}
              </span>
              {{/if}}
              {{#if local_atividade}}
              <span class="flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                {{local_atividade}}
              </span>
              {{/if}}
              {{#if turno}}
              <span class="flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                {{turno}}
              </span>
              {{/if}}
              <span class="flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                Registrado em {{criado_em}}
              </span>
            </div>

            <div class="mt-3 pt-3 border-t border-slate-100 dark:border-white/8 flex items-center justify-end">
              <button type="button"
                data-open-interesse
                data-id="{{id}}"
                data-titulo="{{titulo}}"
                data-tipo="{{tipoLabel}}"
                data-categoria="{{categoria}}"
                data-status="{{statusLabel}}"
                data-quantidade="{{quantidade}}"
                data-data-prevista="{{data_prevista}}"
                data-ong="{{subtitulo}}"
                data-observacao="{{observacao}}"
                data-criado-em="{{criado_em}}"
                class="inline-flex items-center gap-1.5 text-xs font-semibold text-[#4886D9] hover:underline">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
                Ver detalhes
              </button>
            </div>
          </div>
        </div>
      </div>
      {{/each}}
    </div>

    {{> paginationControls}}

    {{else}}

    <div class="flex flex-col items-center justify-center py-20 text-center bg-white dark:bg-white/[0.03] border border-slate-200 dark:border-white/8 rounded-2xl">
      <div class="w-14 h-14 rounded-2xl bg-slate-100 dark:bg-white/8 flex items-center justify-center mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-slate-300 dark:text-white/25" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
        </svg>
      </div>
      <p class="text-sm font-bold text-slate-500 dark:text-white/50 mb-1">Nenhuma atividade encontrada</p>
      <p class="text-xs text-slate-400 dark:text-white/30 max-w-[240px] leading-relaxed mb-5">
        {{#if isTabTodos}}Demonstre interesse em uma necessidade para começar.{{else}}Nenhuma atividade nesta categoria.{{/if}}
      </p>
      {{#unless isTabTodos}}
      <a href="/dashboard"
        class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full border border-slate-200 dark:border-white/10 text-xs font-semibold text-slate-500 dark:text-white/60 hover:opacity-80 transition">
        Ver todas
      </a>
      {{/unless}}
      {{#if isTabTodos}}
      <a href="/necessidades"
        class="inline-block bg-gradient-to-r from-[#4886D9] to-[#2D4BA6] text-white font-bold px-6 py-3 rounded-xl shadow hover:opacity-90 transition text-sm">
        Explorar necessidades
      </a>
      {{/if}}
    </div>

    {{/if}}

  </div>
</section>

<!-- Modal de detalhes do interesse -->
<div id="interesse-modal" class="fixed inset-0 z-50 hidden flex items-center justify-center p-4" aria-modal="true" role="dialog">
  <div id="modal-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
  <div class="relative w-full max-w-lg bg-white dark:bg-[#0d1b2a] rounded-2xl shadow-2xl flex flex-col max-h-[90vh]">

    <!-- Header -->
    <div class="flex items-center justify-between gap-3 px-4 py-3 border-b border-slate-200 dark:border-white/10">
      <div class="flex items-center gap-2 min-w-0">
        <button id="modal-back-btn" class="shrink-0 flex items-center gap-1 text-xs font-semibold text-slate-500 dark:text-white/50 hover:text-[#2D4BA6] dark:hover:text-white transition">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          Voltar
        </button>
        <span id="modal-title" class="font-bold text-[#2D4BA6] dark:text-white text-sm truncate"></span>
      </div>
      <button id="modal-close-btn" class="shrink-0 w-8 h-8 rounded-full border border-slate-200 dark:border-white/10 flex items-center justify-center text-slate-400 hover:text-slate-700 dark:hover:text-white transition">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Body -->
    <div class="flex-1 overflow-y-auto">
      <dl id="modal-body" class="divide-y divide-slate-100 dark:divide-white/8"></dl>

      <!-- Ações -->
      <div id="modal-acoes" class="px-4 py-3 border-t border-slate-100 dark:border-white/8 space-y-2.5">
        <div id="modal-qtd-wrap" class="flex items-center gap-2">
          <label for="modal-qtd" class="text-xs font-semibold text-slate-500 dark:text-white/50 shrink-0">Quantidade</label>
          <input type="number" id="modal-qtd" min="1"
            class="w-24 px-3 py-1.5 rounded-lg border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-[#4886D9] transition" />
        </div>
        <textarea
          id="modal-motivo"
          rows="2"
          placeholder="Observação / motivo..."
          class="w-full px-3 py-2 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white text-sm placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-[#4886D9] resize-none transition"
        ></textarea>

        <div class="flex gap-2 flex-wrap">
          <form id="modal-cancel-form" method="POST" class="flex-1">
            <input type="hidden" name="motivo" id="modal-cancel-motivo" />
            <button type="submit"
              class="w-full py-2 rounded-xl bg-red-500 hover:bg-red-600 text-white text-sm font-semibold transition shadow-sm">
              Cancelar interesse
            </button>
          </form>
          <form id="modal-edit-form" method="POST" class="flex-1">
            <input type="hidden" name="observacao" id="modal-edit-obs" />
            <input type="hidden" name="quantidade" id="modal-edit-qtd" />
            <button type="submit"
              class="w-full py-2 rounded-xl bg-gradient-to-r from-[#4886D9] to-[#2D4BA6] text-white text-sm font-semibold hover:opacity-90 transition shadow-sm">
              Salvar edição
            </button>
          </form>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
(function () {
  var modal    = document.getElementById('interesse-modal');
  var backdrop = document.getElementById('modal-backdrop');
  var closeBtn = document.getElementById('modal-close-btn');
  var backBtn  = document.getElementById('modal-back-btn');
  var title    = document.getElementById('modal-title');
  var body     = document.getElementById('modal-body');

  function row(label, value) {
    if (!value || value === 'null' || value === 'undefined') return '';
    return '<div class="flex items-start justify-between gap-3 px-4 py-2.5">' +
      '<dt class="text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-white/40 shrink-0 w-36">' + label + '</dt>' +
      '<dd class="text-sm text-slate-800 dark:text-white text-right">' + value + '</dd>' +
      '</div>';
  }

  var cancelForm    = document.getElementById('modal-cancel-form');
  var editForm      = document.getElementById('modal-edit-form');
  var motivoArea    = document.getElementById('modal-motivo');
  var cancelInput   = document.getElementById('modal-cancel-motivo');
  var editInput     = document.getElementById('modal-edit-obs');
  var editQtdHidden = document.getElementById('modal-edit-qtd');
  var acoesDiv      = document.getElementById('modal-acoes');
  var qtdInput      = document.getElementById('modal-qtd');
  var qtdWrap       = document.getElementById('modal-qtd-wrap');

  var STATUS_EDITAVEL    = ['Pendente'];
  var STATUS_CANCELAVEL  = ['Pendente', 'Em andamento'];

  function openModal(btn) {
    var d = btn.dataset;
    title.textContent = d.titulo || '';
    motivoArea.value = '';
    qtdInput.value = d.quantidade || '';

    var html = '';
    html += row('ID', '#' + d.id);
    html += row('Necessidade', d.titulo);
    html += row('Tipo', d.tipo);
    html += row('Categoria', d.categoria);
    html += row('Status', d.status);
    html += row('Quantidade', d.quantidade);
    html += row('Data prevista', d.dataPrevista);
    html += row('ONG', d.ong);
    html += row('Registrado em', d.criadoEm);
    html += row('Observação', d.observacao);
    body.innerHTML = html;

    cancelForm.action = '/interesses/' + d.id + '/cancelar';
    editForm.action   = '/interesses/' + d.id + '/editar';

    var podeEditar   = STATUS_EDITAVEL.indexOf(d.status)   !== -1;
    var podeCancelar = STATUS_CANCELAVEL.indexOf(d.status) !== -1;
    acoesDiv.style.display    = (podeEditar || podeCancelar) ? '' : 'none';
    editForm.style.display    = podeEditar   ? '' : 'none';
    cancelForm.style.display  = podeCancelar ? '' : 'none';
    qtdWrap.style.display     = podeEditar   ? '' : 'none';

    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';
    document.documentElement.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = '';
    document.documentElement.style.overflow = '';
  }

  document.querySelectorAll('[data-open-interesse]').forEach(function (btn) {
    btn.addEventListener('click', function () { openModal(btn); });
  });

  cancelForm.addEventListener('submit', function () {
    cancelInput.value = motivoArea.value;
  });
  editForm.addEventListener('submit', function () {
    editInput.value   = motivoArea.value;
    editQtdHidden.value = qtdInput.value;
  });

  closeBtn.addEventListener('click', closeModal);
  backBtn.addEventListener('click', closeModal);
  backdrop.addEventListener('click', closeModal);

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeModal();
  });
})();
</script>
