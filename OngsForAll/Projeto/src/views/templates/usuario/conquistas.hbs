<div class="max-w-3xl mx-auto space-y-8">

  <!-- Cabeçalho -->
  <div>
    <h2 class="text-2xl font-bold text-[#2D4BA6] dark:text-white">Conquistas</h2>
    <p class="text-sm text-slate-500 dark:text-white/60 mt-0.5">Acompanhe seu progresso e os selos que você ganhou</p>
  </div>

  <!-- Card de nível e XP -->
  <div class="relative overflow-hidden bg-gradient-to-br from-[#2D4BA6] to-[#4886D9] rounded-3xl p-7 text-white shadow-lg">
    <div class="absolute -top-10 -right-10 w-48 h-48 rounded-full bg-white/5"></div>
    <div class="absolute -bottom-12 -left-8 w-56 h-56 rounded-full bg-white/5"></div>

    <div class="relative flex items-center justify-between gap-6 flex-wrap">
      <div>
        <p class="text-white/60 text-sm font-medium uppercase tracking-wider">Nível atual</p>
        <p class="text-6xl font-extrabold leading-none mt-1">{{gamificacao.nivel}}</p>
        <p class="text-white/80 text-lg font-semibold mt-1">{{gamificacao.nivelLabel}}</p>
      </div>
      <div class="text-right">
        <p class="text-white/60 text-sm font-medium">XP Total</p>
        <p class="text-4xl font-extrabold">{{gamificacao.totalAcumulado}}</p>
        <p class="text-white/60 text-sm mt-0.5">próximo nível: {{gamificacao.proximoNivelXP}} XP</p>
      </div>
    </div>

    <!-- Barra de progresso -->
    <div class="relative mt-6">
      <div class="flex justify-between text-xs text-white/60 mb-2">
        <span>Progresso para o próximo nível</span>
        <span>{{gamificacao.progressoXP}}%</span>
      </div>
      <div class="h-3 bg-white/20 rounded-full overflow-hidden">
        <div class="h-full bg-white rounded-full transition-all duration-700"
          style="width: {{gamificacao.progressoXP}}%"></div>
      </div>
    </div>
  </div>

  <!-- Trilha de níveis -->
  <div class="bg-white dark:bg-[#102235] border border-slate-200 dark:border-white/10 rounded-2xl p-6 shadow-sm">
    <h3 class="text-sm font-semibold uppercase tracking-wider text-slate-400 dark:text-white/40 mb-5">Trilha de evolução</h3>
    <div class="flex items-center gap-0">
      {{#each gamificacao.niveis}}
      <div class="flex items-center flex-1 {{#unless @last}}flex-1{{/unless}}">
        <!-- Círculo do nível -->
        <div class="flex flex-col items-center shrink-0">
          <div class="w-10 h-10 rounded-full flex items-center justify-center font-bold text-sm border-2 transition-all
            {{#if concluido}}bg-[#2D4BA6] border-[#2D4BA6] text-white{{/if}}
            {{#if ativo}}bg-white dark:bg-[#0D1B2A] border-[#4886D9] text-[#4886D9] ring-4 ring-[#4886D9]/20{{/if}}
            {{#unless concluido}}{{#unless ativo}}bg-slate-100 dark:bg-white/5 border-slate-200 dark:border-white/10 text-slate-400 dark:text-white/30{{/unless}}{{/unless}}">
            {{#if concluido}}✓{{else}}{{numero}}{{/if}}
          </div>
          <p class="text-[10px] font-semibold mt-1.5 text-center w-16
            {{#if ativo}}text-[#4886D9]{{else}}text-slate-400 dark:text-white/30{{/if}}">
            {{label}}
          </p>
          <p class="text-[9px] text-slate-300 dark:text-white/20">{{xpMin}} XP</p>
        </div>
        <!-- Linha conectora -->
        {{#unless @last}}
        <div class="flex-1 h-0.5 mx-1 mb-6
          {{#if concluido}}bg-[#2D4BA6]{{else}}bg-slate-200 dark:bg-white/10{{/if}}"></div>
        {{/unless}}
      </div>
      {{/each}}
    </div>
  </div>

  <!-- Selos -->
  <div class="bg-white dark:bg-[#102235] border border-slate-200 dark:border-white/10 rounded-2xl p-6 shadow-sm">
    <div class="flex items-center justify-between mb-5">
      <h3 class="text-sm font-semibold uppercase tracking-wider text-slate-400 dark:text-white/40">Selos</h3>
      <span class="text-xs font-semibold text-[#4886D9] bg-[#4886D9]/10 dark:bg-[#4886D9]/20 px-2.5 py-1 rounded-full">
        {{gamificacao.totalConquistados}} / {{gamificacao.totalSelos}}
      </span>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {{#each gamificacao.selos}}
      <div class="flex items-center gap-4 p-4 rounded-2xl border transition-all
        {{#if conquistado}}
          border-[#4886D9]/30 dark:border-[#4886D9]/30 bg-[#2D4BA6]/5 dark:bg-[#4886D9]/10
        {{else}}
          border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5
        {{/if}}">

        <!-- Ícone -->
        <div class="relative w-12 h-12 rounded-2xl flex items-center justify-center shrink-0 text-2xl
          {{#if conquistado}}
            bg-white dark:bg-[#0D1B2A] shadow-sm border border-[#4886D9]/20
          {{else}}
            bg-slate-100 dark:bg-white/10 grayscale
          {{/if}}">
          {{icone}}
          {{#unless conquistado}}
          <div class="absolute inset-0 rounded-2xl bg-slate-200/60 dark:bg-black/40 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-400 dark:text-white/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>
          {{/unless}}
        </div>

        <!-- Info -->
        <div class="min-w-0 flex-1">
          <p class="font-semibold text-sm
            {{#if conquistado}}text-[#2D4BA6] dark:text-white{{else}}text-slate-500 dark:text-white/60{{/if}}">
            {{nome}}
          </p>
          <p class="text-xs mt-0.5
            {{#if conquistado}}text-slate-500 dark:text-white/50{{else}}text-slate-400 dark:text-white/40{{/if}}">
            {{descricao}}
          </p>
          {{#if conquistado_em}}
          <p class="text-[10px] text-[#4886D9]/70 dark:text-[#4886D9]/60 mt-1 font-medium">Conquistado em {{conquistado_em}}</p>
          {{/if}}
          {{#unless conquistado}}
          <p class="text-[10px] text-slate-400 dark:text-white/30 mt-1">Ainda não desbloqueado</p>
          {{/unless}}
        </div>

        {{#if conquistado}}
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[#4886D9] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        {{/if}}
      </div>
      {{/each}}
    </div>
  </div>

  <!-- Como ganhar XP -->
  <div class="bg-white dark:bg-[#102235] border border-slate-200 dark:border-white/10 rounded-2xl p-6 shadow-sm">
    <h3 class="text-sm font-semibold uppercase tracking-wider text-slate-400 dark:text-white/40 mb-4">Como ganhar XP</h3>
    <div class="space-y-3">
      <div class="flex items-center justify-between py-2 border-b border-slate-100 dark:border-white/5">
        <p class="text-sm text-slate-700 dark:text-white/80">Demonstrar interesse em ajudar</p>
        <span class="text-sm font-bold text-[#4886D9]">+10 XP</span>
      </div>
      <div class="flex items-center justify-between py-2 border-b border-slate-100 dark:border-white/5">
        <p class="text-sm text-slate-700 dark:text-white/80">Contribuição confirmada pela ONG</p>
        <span class="text-sm font-bold text-[#4886D9]">+20 XP</span>
      </div>
      <div class="flex items-center justify-between py-2">
        <p class="text-sm text-slate-700 dark:text-white/80">Participar de voluntariado confirmado</p>
        <span class="text-sm font-bold text-[#4886D9]">+25 XP</span>
      </div>
    </div>
  </div>

</div>
