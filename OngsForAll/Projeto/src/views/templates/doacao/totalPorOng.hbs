<div class="max-w-3xl mx-auto space-y-6">

  <div>
    <h2 class="text-2xl font-bold text-[#2D4BA6] dark:text-white">Total de doações por ONG</h2>
    <p class="text-sm text-slate-500 dark:text-white/60 mt-0.5">Visão consolidada de quanto cada ONG recebeu</p>
  </div>

  <div class="bg-white dark:bg-[#102235] border border-slate-200 dark:border-white/10 rounded-2xl shadow-sm overflow-hidden">
    {{#if dados.length}}
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="border-b border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5">
            <th class="px-5 py-3.5 text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-white/50">ONG</th>
            <th class="px-5 py-3.5 text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-white/50 text-right">Total recebido</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 dark:divide-white/5">
          {{#each dados}}
          <tr class="hover:bg-slate-50 dark:hover:bg-white/5 transition-colors duration-150">
            <td class="px-5 py-4 text-sm font-medium text-slate-800 dark:text-white">{{this.nome}}</td>
            <td class="px-5 py-4 text-sm font-semibold text-[#2D4BA6] dark:text-[#4886D9] text-right">R$ {{this.total}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
    {{else}}
    <div class="p-16 text-center">
      <div class="w-14 h-14 rounded-2xl bg-slate-100 dark:bg-white/5 flex items-center justify-center mx-auto mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-slate-300 dark:text-white/20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
      </div>
      <p class="text-slate-500 dark:text-white/50 font-medium">Nenhuma ONG recebeu doações ainda</p>
    </div>
    {{/if}}
  </div>

  <div class="pt-2">
    <a href="/dashboard/ong" class="text-sm text-[#4886D9] dark:text-[#4886D9] hover:underline font-semibold">
      ← Voltar ao dashboard
    </a>
  </div>

</div>
